{% extends 'layouts/base.html.twig' %}

{% block title %}
  Création du mot de passe
{% endblock %}

{% block body %}
  <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="max-width: 650px; width: 100%; border-radius: 12px;">
      <div class="card-header text-center text-white" style="border-radius: 12px 12px 0 0; background-color: #1f2937;">
        <h2 class="mb-0">Création du mot de passe</h2>
      </div>

      <div class="card-body p-4">
        <section class="">
          <div class="container_fuild">
            <div class="row">
              <div class="col-md-12">
                <div class="full text-center">
                  <h3 class="mt-2">Entrez votre mot de passe</h3>
                  <hr style="width: 40%; margin: 10px auto;" />
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="why_section layout_padding mt-3">
          <div class="container">
            <div class="row">
              <div class="col-lg-8 offset-lg-2">
                <div class="full">
                  {# Flash messages success / danger #}
                  {% for label, messages in app.flashes(['success', 'danger']) %}
                    {% for message in messages %}
                      <div class="alert alert-{{ label }} text-center mb-3">{{ message }}</div>
                    {% endfor %}
                  {% endfor %}

                  <form method="post">
                    {# CSRF token #}
                    <input type="hidden" name="{{ resetForm._token.vars.full_name }}" value="{{ resetForm._token.vars.value }}" />

                    {# Nouveau mot de passe #}
                    <label for="{{ resetForm.plainPassword.first.vars.id }}">Nouveau mot de passe</label>
                    <input type="password" id="{{ resetForm.plainPassword.first.vars.id }}" name="{{ resetForm.plainPassword.first.vars.full_name }}" class="input" placeholder="Entrez votre nouveau mot de passe" required />
                    {# Affichage des erreurs du premier champ #}
                    {% for error in resetForm.plainPassword.first.vars.errors %}
                      <div class="alert alert-danger mt-1">{{ error.message }}</div>
                    {% endfor %}

                    {# Répéter le mot de passe #}
                    <label for="{{ resetForm.plainPassword.second.vars.id }}" class="mt-3">Répétez le mot de passe</label>
                    <input type="password" id="{{ resetForm.plainPassword.second.vars.id }}" name="{{ resetForm.plainPassword.second.vars.full_name }}" class="input" placeholder="Répétez votre mot de passe" required />
                    {# Affichage des erreurs du second champ #}
                    {% for error in resetForm.plainPassword.second.vars.errors %}
                      <div class="alert alert-danger mt-1">{{ error.message }}</div>
                    {% endfor %}

                    <input type="submit" value="Créer" class="button is-primary is-fullwidth mt-3" />
                  </form>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
{% endblock %}
