{% extends 'layouts/base.html.twig' %}

{% block title %}
	Réinitialisation du mot de passe — Gestion Écurie
{% endblock %}

{% block body %}
	<div class="login-page">
		<div class="login-box anim-fade-up">

			<div class="login-header">
				<div class="login-icon">
					<i class="mdi mdi-lock-outline"></i>
				</div>
				<h1 class="login-title">Nouveau mot de passe</h1>
				<p class="login-subtitle">Choisissez un mot de passe sécurisé pour votre compte</p>
			</div>

			<div class="login-card">
				{% for flash_error in app.flashes('reset_password_error') %}
					<div class="login-alert">
						<i class="mdi mdi-alert-circle-outline"></i>
						<span>{{ flash_error }}</span>
					</div>
				{% endfor %}

				<form method="post" class="login-form">
					<input type="hidden" name="{{ resetForm._token.vars.full_name }}" value="{{ resetForm._token.vars.value }}"/>

					<div class="login-field">
						<label class="login-label" for="{{ resetForm.plainPassword.first.vars.id }}">
							Nouveau mot de passe
						</label>
						<div class="login-input-wrap">
							<i class="mdi mdi-lock-outline login-input-icon"></i>
							<input class="login-input" type="password" id="{{ resetForm.plainPassword.first.vars.id }}" name="{{ resetForm.plainPassword.first.vars.full_name }}" placeholder="••••••••" autocomplete="new-password" required autofocus/>
						</div>
						{% for error in resetForm.plainPassword.first.vars.errors %}
							<div class="login-alert" style="margin-top: 6px;">
								<i class="mdi mdi-alert-circle-outline"></i>
								<span>{{ error.message }}</span>
							</div>
						{% endfor %}
					</div>

					<div class="login-field">
						<label class="login-label" for="{{ resetForm.plainPassword.second.vars.id }}">
							Confirmer le mot de passe
						</label>
						<div class="login-input-wrap">
							<i class="mdi mdi-lock-check-outline login-input-icon"></i>
							<input class="login-input" type="password" id="{{ resetForm.plainPassword.second.vars.id }}" name="{{ resetForm.plainPassword.second.vars.full_name }}" placeholder="••••••••" autocomplete="new-password" required/>
						</div>
						{% for error in resetForm.plainPassword.second.vars.errors %}
							<div class="login-alert" style="margin-top: 6px;">
								<i class="mdi mdi-alert-circle-outline"></i>
								<span>{{ error.message }}</span>
							</div>
						{% endfor %}
					</div>

					<button type="submit" class="login-submit">
						<i class="mdi mdi-check-circle-outline"></i>
						Enregistrer le mot de passe
					</button>
				</form>
			</div>

			<div class="login-footer">
				<a href="{{ path('app_login') }}">
					<i class="mdi mdi-arrow-left"></i>
					Retour à la connexion
				</a>
			</div>

		</div>
	</div>
{% endblock %}
