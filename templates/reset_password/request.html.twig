{% extends 'layouts/base.html.twig' %}

{% block title %}
	Mot de passe oublié — Gestion Écurie
{% endblock %}

{% block body %}
	<div class="login-page">
		<div class="login-box anim-fade-up">

			<div class="login-header">
				<div class="login-icon">
					<i class="mdi mdi-lock-reset"></i>
				</div>
				<h1 class="login-title">Mot de passe oublié</h1>
				<p class="login-subtitle">Saisissez votre email pour recevoir un lien de réinitialisation</p>
			</div>

			<div class="login-card">
				{% for flash_error in app.flashes('reset_password_error') %}
					<div class="login-alert">
						<i class="mdi mdi-alert-circle-outline"></i>
						<span>{{ flash_error }}</span>
					</div>
				{% endfor %}

				{{ form_start(requestForm, { attr: { class: 'login-form' } }) }}
				<div class="login-field">
					<label class="login-label" for="{{ requestForm.email.vars.id }}">Adresse email</label>
					<div class="login-input-wrap">
						<i class="mdi mdi-email-outline login-input-icon"></i>
						{{ form_widget(requestForm.email, {
                attr: {
                  class: 'login-input',
                  placeholder: 'votre@email.com',
                  autocomplete: 'email',
                  autofocus: true
                }
              }) }}
					</div>
					{{ form_errors(requestForm.email) }}
				</div>

				<button type="submit" class="nav-btn login-submit">
					<i class="mdi mdi-send-outline"></i>
					Envoyer le lien de réinitialisation
				</button>
				{{ form_end(requestForm) }}
			</div>

			<div class="login-footer">
				<a href="{{ path('app_login') }}">
					<i class="mdi mdi-arrow-left"></i>
					Retour à la connexion
				</a>
			</div>

		</div>
	</div>
{% endblock %}
