<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {% block title %}
        Gestion Écurie | BackOffice
      {% endblock %}
    </title>

    <link rel="stylesheet" href="{{ asset('assets/css/main.min.css') }}" />
    <link rel="stylesheet" href="{{ asset('assets/css/admin.css') }}" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.materialdesignicons.com/4.9.95/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.5/css/dataTables.bulma.css" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link href="https://fonts.googleapis.com/css?family=Nunito" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

    <style>
      /* ══════════════════════════════════════
                                       RESET & BASE
                                    ══════════════════════════════════════ */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      
      :root {
        --sidebar-w: 260px;
        --navbar-h: 56px;
      
        --bg: #f0ede8;
        --surface: #faf9f7;
        --surface-2: #f2f0eb;
        --ink: #1a1714;
        --ink-soft: #6b6560;
        --ink-muted: #a09b96;
        --border: #e3dfd8;
      
        /* Sidebar dark */
        --sidebar-bg: #111827;
        --sidebar-bg-2: #1a2535;
        --sidebar-text: #cbd5e1;
        --sidebar-text-muted: #64748b;
        --sidebar-active-bg: rgba(255, 255, 255, 0.08);
        --sidebar-active-text: #ffffff;
        --sidebar-hover-bg: rgba(255, 255, 255, 0.05);
        --sidebar-accent: #4f80c4;
      
        --shadow-sm: 0 2px 8px rgba(26, 23, 20, 0.06);
        --shadow-md: 0 8px 32px rgba(26, 23, 20, 0.1);
        --radius: 12px;
        --radius-sm: 8px;
      
        --transition: 0.22s cubic-bezier(0.4, 0, 0.2, 1);
      }
      
      html,
      body {
        height: 100%;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--ink);
        font-size: 15px;
      }
      
      /* ══════════════════════════════════════
                                       LAYOUT SHELL
                                    ══════════════════════════════════════ */
      .shell {
        display: flex;
        min-height: 100vh;
      }
      
      /* ══════════════════════════════════════
                                       SIDEBAR
                                    ══════════════════════════════════════ */
      .sidebar {
        width: var(--sidebar-w);
        background: var(--sidebar-bg);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.08) transparent;
        transition: transform var(--transition);
      }
      
      .sidebar::-webkit-scrollbar {
        width: 4px;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
      }
      
      /* Brand */
      .sidebar-brand {
        padding: 1.5rem 1.5rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        flex-shrink: 0;
      }
      
      .brand-label {
        font-family: 'Sora', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sidebar-text-muted);
        margin-bottom: 0.3rem;
      }
      
      .brand-name {
        font-family: 'Sora', sans-serif;
        font-size: 1.15rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        line-height: 1.2;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      
      .brand-name .brand-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--sidebar-accent);
        flex-shrink: 0;
      }
      
      /* Nav */
      .sidebar-nav {
        flex: 1;
        padding: 1.25rem 0.75rem;
      }
      
      .nav-section-label {
        font-family: 'Sora', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sidebar-text-muted);
        padding: 0 0.75rem;
        margin: 1.25rem 0 0.4rem;
      }
      
      .nav-section-label:first-child {
        margin-top: 0;
      }
      
      .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0.75rem;
        border-radius: var(--radius-sm);
        color: var(--sidebar-text);
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        transition: all var(--transition);
        position: relative;
        user-select: none;
      }
      
      .nav-item:hover {
        background: var(--sidebar-hover-bg);
        color: #fff;
      }
      
      .nav-item.active {
        background: var(--sidebar-active-bg);
        color: var(--sidebar-active-text);
      }
      
      .nav-item.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 20%;
        bottom: 20%;
        width: 3px;
        border-radius: 0 3px 3px 0;
        background: var(--sidebar-accent);
      }
      
      .nav-item .nav-icon {
        font-size: 1rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
        opacity: 0.75;
        transition: opacity var(--transition);
      }
      
      .nav-item:hover .nav-icon,
      .nav-item.active .nav-icon {
        opacity: 1;
      }
      
      .nav-item .nav-label {
        flex: 1;
      }
      
      .nav-item .nav-arrow {
        font-size: 0.75rem;
        opacity: 0.5;
        transition: transform var(--transition), opacity var(--transition);
      }
      
      .nav-item.open .nav-arrow {
        transform: rotate(180deg);
        opacity: 0.9;
      }
      
      /* Submenu */
      .submenu {
        display: none;
        padding: 0.25rem 0 0.25rem 2.25rem;
      }
      
      .submenu.open {
        display: block;
      }
      
      .submenu-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-sm);
        color: var(--sidebar-text-muted);
        text-decoration: none;
        font-size: 0.83rem;
        font-weight: 400;
        transition: all var(--transition);
      }
      
      .submenu-item:hover {
        color: #fff;
        background: var(--sidebar-hover-bg);
      }
      
      .submenu-item .mdi,
      .submenu-item .bi {
        font-size: 0.85rem;
        opacity: 0.7;
      }
      
      /* Sidebar footer */
      .sidebar-footer {
        padding: 1rem 0.75rem;
        border-top: 1px solid rgba(255, 255, 255, 0.07);
        flex-shrink: 0;
      }
      
      /* ══════════════════════════════════════
                                       MAIN AREA
                                    ══════════════════════════════════════ */
      .main-area {
        margin-left: var(--sidebar-w);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      
      /* ══════════════════════════════════════
                                       TOP NAVBAR
                                    ══════════════════════════════════════ */
      .topbar {
        height: var(--navbar-h);
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 2rem;
        gap: 1rem;
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: var(--shadow-sm);
      }
      
      .topbar-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid var(--border);
      }
      
      .topbar-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      
      .topbar-logout {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 1rem;
        border-radius: 100px;
        font-family: 'Sora', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        color: var(--ink-soft);
        border: 1.5px solid var(--border);
        text-decoration: none;
        transition: all var(--transition);
        background: transparent;
      }
      
      .topbar-logout:hover {
        color: var(--ink);
        border-color: var(--ink-soft);
        background: var(--surface-2);
      }
      
      /* ══════════════════════════════════════
                                       PAGE CONTENT
                                    ══════════════════════════════════════ */
      .page-content {
        flex: 1;
        padding: 0;
      }
      
      /* ══════════════════════════════════════
                                       FOOTER
                                    ══════════════════════════════════════ */
      .site-footer {
        padding: 1.25rem 2rem;
        font-size: 0.78rem;
        color: var(--ink-muted);
        border-top: 1px solid var(--border);
        background: var(--surface);
        font-family: 'Sora', sans-serif;
        letter-spacing: 0.02em;
      }
      
      /* ══════════════════════════════════════
                                       MOBILE TOGGLE
                                    ══════════════════════════════════════ */
      .mobile-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--ink);
        font-size: 1.3rem;
        padding: 0.3rem;
      }
      
      @media (max-width: 900px) {
        .sidebar {
          transform: translateX(-100%);
        }
      
        .sidebar.open {
          transform: translateX(0);
          box-shadow: 0 0 0 100vw rgba(0, 0, 0, 0.4);
        }
      
        .main-area {
          margin-left: 0;
        }
      
        .mobile-toggle {
          display: flex;
          margin-right: auto;
        }
      
        .topbar {
          padding: 0 1rem;
        }
      }

      /* ══════════════════════════════════════
         FORM ERROR HANDLING
      ══════════════════════════════════════ */
      .form-error-summary {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: var(--radius-sm);
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
      }
      .form-error-summary-title {
        font-family: 'Sora', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        color: #b91c1c;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .form-error-summary-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .form-error-summary-list li {
        font-size: 0.82rem;
        color: #dc2626;
        padding: 0.2rem 0;
        padding-left: 1rem;
        position: relative;
      }
      .form-error-summary-list li::before {
        content: '•';
        position: absolute;
        left: 0;
        color: #f87171;
      }
      .form-field.has-error .input,
      .form-field.has-error select,
      .form-field.has-error textarea {
        border-color: #dc2626 !important;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
      }
      .field-error {
        color: #dc2626;
        font-size: 0.78rem;
        margin-top: 0.25rem;
      }
    </style>
  </head>

  <body>
    {% set currentPath = app.request.attributes.get('_route') %}

    <div class="shell">
      {# ══ SIDEBAR ══ #}
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
          <div class="brand-label">BackOffice</div>
          <div class="brand-name">
            <span class="brand-dot"></span>
            Gestion Écurie
          </div>
        </div>

        <nav class="sidebar-nav">
          <div class="nav-section-label">Général</div>

          <a href="{{ path('app_admin') }}" class="nav-item {% if currentPath == 'app_admin' %}{% endif %}">
            <i class="nav-icon mdi mdi-desktop-mac"></i>
            <span class="nav-label">Tableau de bord</span>
          </a>

          <div class="nav-section-label">Menu</div>

          <a href="{{ path('app_admin_users') }}" class="nav-item {% if currentPath starts with 'app_admin_user' %}{% endif %}">
            <i class="nav-icon mdi mdi-account-circle"></i>
            <span class="nav-label">Utilisateurs</span>
          </a>

          <a href="{{ path('app_admin_entreprises') }}" class="nav-item {% if currentPath starts with 'app_admin_entreprise' %}{% endif %}">
            <i class="nav-icon mdi mdi-domain"></i>
            <span class="nav-label">Entreprises</span>
          </a>

          {# Gestion financière #}
          <div class="nav-item toggle-nav {% if currentPath in ['app_admin_mois_gestion', 'app_admin_facturation_utilisateur'] %}{% endif %}" data-target="sub-finance">
            <i class="nav-icon mdi mdi-finance"></i>
            <span class="nav-label">Gestion financière</span>
            <i class="nav-arrow mdi mdi-chevron-down"></i>
          </div>
          <div class="submenu {% if currentPath in ['app_admin_mois_gestion', 'app_admin_facturation_utilisateur'] %}{% endif %}" id="sub-finance">
            <a href="{{ path('app_admin_mois_gestion') }}" class="submenu-item"><i class="mdi mdi-calendar-month"></i> Relevés</a>
            <a href="{{ path('app_admin_facturation_utilisateur') }}" class="submenu-item"><i class="mdi mdi-file-document-outline"></i> Facturation</a>
          </div>

          {# Chevaux & Courses #}
          <div class="nav-item toggle-nav {% if currentPath in ['app_admin_chevaux', 'app_admin_courses', 'app_admin_participations'] %}{% endif %}" data-target="sub-chevaux">
            <i class="nav-icon mdi mdi-horseshoe"></i>
            <span class="nav-label">Chevaux & Courses</span>
            <i class="nav-arrow mdi mdi-chevron-down"></i>
          </div>
          <div class="submenu {% if currentPath in ['app_admin_chevaux', 'app_admin_courses', 'app_admin_participations'] %}{% endif %}" id="sub-chevaux">
            <a href="{{ path('app_admin_chevaux') }}" class="submenu-item"><i class="mdi mdi-chess-knight"></i> Chevaux</a>
            <a href="{{ path('app_admin_courses') }}" class="submenu-item"><i class="mdi mdi-flag-checkered"></i> Courses</a>
            <a href="{{ path('app_admin_participations') }}" class="submenu-item"><i class="mdi mdi-ticket-confirmation"></i> Participations</a>
          </div>

          <a href="{{ path('app_admin_structures') }}" class="nav-item {% if currentPath == 'app_admin_structures' %}{% endif %}">
            <i class="nav-icon mdi mdi-office-building"></i>
            <span class="nav-label">Structure</span>
          </a>

          {# Distance & Déplacements #}
          <div class="nav-item toggle-nav {% if currentPath in ['app_admin_deplacements', 'app_admin_distances'] %}{% endif %}" data-target="sub-deplac">
            <i class="nav-icon mdi mdi-car"></i>
            <span class="nav-label">Distance & Déplacements</span>
            <i class="nav-arrow mdi mdi-chevron-down"></i>
          </div>
          <div class="submenu {% if currentPath in ['app_admin_deplacements', 'app_admin_distances'] %}{% endif %}" id="sub-deplac">
            <a href="{{ path('app_admin_deplacements') }}" class="submenu-item"><i class="mdi mdi-car"></i> Déplacements</a>
            <a href="{{ path('app_admin_distances') }}" class="submenu-item"><i class="mdi mdi-map-marker-distance"></i> Distances</a>
          </div>

          <a href="{{ path('app_admin_produits') }}" class="nav-item {% if currentPath == 'app_admin_produits' %}{% endif %}">
            <i class="nav-icon mdi mdi-barcode-scan"></i>
            <span class="nav-label">Produits</span>
          </a>
        </nav>

        <div class="sidebar-footer">
          <a href="{{ path('app_home') }}" class="nav-item" style="color: #ef4444;">
            <i class="nav-icon mdi mdi-logout" style="color: #ef4444;"></i>
            <span class="nav-label">Quitter</span>
          </a>
        </div>
      </aside>

      {# ══ MAIN ══ #}
      <div class="main-area">
        <header class="topbar">
          <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu"><i class="mdi mdi-menu"></i></button>

          <div class="topbar-avatar">
            <img src="https://avatars.dicebear.com/v2/initials/admin.svg" alt="Admin" />
          </div>

          <a href="{{ path('app_logout') }}" class="topbar-logout">
            <i class="mdi mdi-logout"></i>
            Déconnexion
          </a>
        </header>

        <main class="page-content">
          {% block body %}

          {% endblock %}
        </main>

        <footer class="site-footer">© {{ 'now'|date('Y') }} — Logiciel pour tous</footer>
      </div>
    </div>

    {# Scripts #}
    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
    <script src="https://cdn.datatables.net/2.3.5/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.5/js/dataTables.bulma.js"></script>
    <script src="{{ asset('assets/js/main.min.js') }}"></script>
    <script src="{{ asset('assets/js/admin.js') }}"></script>

    <script>
      // Submenu toggles — plusieurs sections ouvertes simultanément
      document.querySelectorAll('.toggle-nav').forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          const targetId = this.getAttribute('data-target')
          const sub = document.getElementById(targetId)

          sub.classList.toggle('open')
          this.classList.toggle('open')
        })
      })
      
      // Mobile sidebar
      const sidebar = document.getElementById('sidebar')
      const toggle = document.getElementById('mobile-toggle')
      
      toggle.addEventListener('click', function () {
        sidebar.classList.toggle('open')
      })
      
      sidebar.addEventListener('click', function (e) {
        if (window.innerWidth <= 900 && e.target === sidebar) {
          sidebar.classList.remove('open')
        }
      })
      
      // DataTable
      if (document.getElementById('table')) {
        new DataTable('#table', {
          language: { url: 'https://cdn.datatables.net/plug-ins/2.3.5/i18n/fr-FR.json' }
        })
      }

      // Anti double-clic — spinner sur les boutons submit
      document.querySelectorAll('form').forEach(function (form) {
        form.addEventListener('submit', function () {
          var btn = form.querySelector('button[type="submit"], input[type="submit"]');
          if (btn && !btn.classList.contains('is-loading')) {
            btn.classList.add('is-loading');
          }
        });
      });

      // Field error highlighting
      document.querySelectorAll('.field-error').forEach(function(el) {
        if (el.textContent.trim() !== '') {
          var field = el.closest('.form-field');
          if (field) field.classList.add('has-error');
        }
      });
      // Scroll to error summary if present
      var errorSummary = document.querySelector('.form-error-summary');
      if (errorSummary) {
        errorSummary.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    </script>
  </body>
</html>
