{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | Tableau de bord
{% endblock %}

{% block body %}
  <div class="admin-wrapper">
    {# ── Page title ── #}
    <div class="page-top">
      <div class="page-eyebrow">Admin › Backoffice</div>
      <h1 class="page-title">Tableau de bord</h1>
    </div>

    {# ── KPIs ── #}
    <div class="kpi-grid">
      <div class="kpi-card c-dark">
        <div class="kpi-icon c-dark">
          <i class="bi bi-people-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Utilisateurs</div>
          <div class="kpi-value">{{ users|length }}</div>
        </div>
      </div>
      <div class="kpi-card c-blue">
        <div class="kpi-icon c-blue">
          <i class="bi bi-building"></i>
        </div>
        <div>
          <div class="kpi-label">Entreprises</div>
          <div class="kpi-value">{{ entreprises|length }}</div>
        </div>
      </div>
      <div class="kpi-card c-green">
        <div class="kpi-icon c-green">
          <i class="bi bi-heart-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Chevaux</div>
          <div class="kpi-value">{{ chevaux|length }}</div>
        </div>
      </div>
      <div class="kpi-card c-gold">
        <div class="kpi-icon c-gold">
          <i class="bi bi-cash-stack"></i>
        </div>
        <div>
          <div class="kpi-label">Chiffre d'affaires</div>
          <div class="kpi-value">{{ totalCA|number_format(0, ',', ' ') }} €</div>
        </div>
      </div>
    </div>

    {# ── Bottom two-col layout ── #}
    <div class="two-col">
      {# ── Déplacements ── #}
      <div class="section-card">
        <div class="section-header">
          <div class="section-icon">
            <i class="bi bi-geo-alt-fill"></i>
          </div>
          <h4 class="section-title">Déplacements ce mois</h4>
        </div>
        <div class="section-body">
          {% set maxCount = 1 %}
          {% for entreprise, count in deplacementsParEntreprise %}
            {% if count > maxCount %}{% set maxCount = count %}{% endif %}
          {% endfor %}
          {% for entreprise, count in deplacementsParEntreprise %}
            <div class="progress-row">
              <div class="progress-label" title="{{ entreprise }}">{{ entreprise }}</div>
              <div class="progress-track">
                <div class="progress-fill" style="width: {{ (count / maxCount * 100)|round }}%"></div>
              </div>
              <div class="progress-count">{{ count }}</div>
            </div>
          {% else %}
            <div class="empty-state">
              <i class="bi bi-geo-alt" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;opacity:0.4"></i>
              Aucun déplacement ce mois-ci.
            </div>
          {% endfor %}
        </div>
      </div>

      {# ── Factures impayées ── #}
      <div class="section-card" style="padding:0;overflow:hidden;">
        <div class="section-header" style="padding:1.5rem 2rem;margin-bottom:0;">
          <div class="section-icon" style="background:var(--red-light);color:var(--red);">
            <i class="bi bi-receipt"></i>
          </div>
          <h4 class="section-title">Factures impayées</h4>
          {% if (facturesImpayees|length) > 0 %}
            <span class="count-badge" style="margin-left:auto;background:var(--red-light);color:var(--red);">{{ facturesImpayees|length }}</span>
          {% endif %}
        </div>

        {% if (facturesImpayees|length) > 0 %}
          <div style="overflow-x:auto;">
            <table class="data-table" style="min-width:520px;">
              <thead>
                <tr>
                  <th style="white-space:nowrap;">N°</th>
                  <th style="white-space:nowrap;">Utilisateur</th>
                  <th style="white-space:nowrap;">Entreprise</th>
                  <th style="white-space:nowrap;text-align:right;">Total</th>
                  <th style="white-space:nowrap;">Statut</th>
                </tr>
              </thead>
              <tbody>
                {% for facture in facturesImpayees %}
                  <tr>
                    <td style="white-space:nowrap;">
                      <span class="invoice-num">{{ facture.numFacture }}</span>
                    </td>
                    <td style="max-width:130px;">
                      <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.88rem;">{{ facture.utilisateur.username ?? '—' }}</span>
                    </td>
                    <td style="max-width:130px;">
                      <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.88rem;color:var(--ink-soft);">{{ facture.entreprise.nom ?? '—' }}</span>
                    </td>
                    <td style="white-space:nowrap;text-align:right;">
                      <span class="amount">{{ facture.total|number_format(2, ',', ' ') }} €</span>
                    </td>
                    <td style="white-space:nowrap;">
                      <span class="status-badge">{{ facture.statut }}</span>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div class="empty-state" style="padding:2.5rem;">
            <i class="bi bi-check-circle" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;opacity:0.4;color:var(--green)"></i>
            Aucune facture impayée.
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
