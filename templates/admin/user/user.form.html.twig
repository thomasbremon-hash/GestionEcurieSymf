{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ userId is not null ? 'Modifier' : 'Ajouter' }} un utilisateur
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_users') }}">Utilisateurs</a>
      <span class="sep">›</span>
      <span class="current">{{ userId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Utilisateurs</div>
        <h1 class="page-title">{{ userId is not null ? "Modifier l'utilisateur" : 'Ajouter un utilisateur' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon">
          <i class="mdi mdi-{{ userId is not null ? 'account-edit' : 'account-plus' }}"></i>
        </div>
        <h2 class="form-card-title">{{ userId is not null ? 'Modifier les informations' : 'Nouveau compte utilisateur' }}</h2>
      </div>

      {{ form_start(formUser, { attr: { novalidate: 'novalidate' } }) }}
      {% include 'admin/_form_errors.html.twig' with { form: formUser } %}

      <div class="form-body">
        {# ── Identité ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-account-outline"></i> Identité
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formUser.prenom) }}
              {{ form_widget(formUser.prenom) }}
              <div class="field-error">{{ form_errors(formUser.prenom) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formUser.nom) }}
              {{ form_widget(formUser.nom) }}
              <div class="field-error">{{ form_errors(formUser.nom) }}</div>
            </div>
          </div>
        </div>

        {# ── Connexion ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-lock-outline"></i> Connexion
          </div>
          <div class="fields-row cols-1">
            <div class="form-field">
              {{ form_label(formUser.email) }}
              {{ form_widget(formUser.email) }}
              <div class="field-error">{{ form_errors(formUser.email) }}</div>
            </div>
          </div>
        </div>

        {# ── Adresse ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-map-marker-outline"></i> Adresse
          </div>
          <div class="fields-row cols-1" style="margin-bottom:1.25rem;">
            <div class="form-field">
              {{ form_label(formUser.rue) }}
              {{ form_widget(formUser.rue) }}
              <div class="field-error">{{ form_errors(formUser.rue) }}</div>
            </div>
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formUser.ville) }}
              {{ form_widget(formUser.ville) }}
              <div class="field-error">{{ form_errors(formUser.ville) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formUser.cp) }}
              {{ form_widget(formUser.cp) }}
              <div class="field-error">{{ form_errors(formUser.cp) }}</div>
            </div>
          </div>
          <div class="fields-row cols-1" style="margin-top:1.25rem;">
            <div class="form-field">
              {{ form_label(formUser.pays) }}
              {{ form_widget(formUser.pays) }}
              <div class="field-error">{{ form_errors(formUser.pays) }}</div>
            </div>
          </div>
        </div>

        {# ── Rôles ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-shield-account-outline"></i> Rôles
          </div>
          <div class="checkbox-grid">
            {% for choice in formUser.roles %}
              <label class="checkbox-item">
                {{ form_widget(choice) }}
                <span>{{ choice.vars.label }}</span>
              </label>
            {% endfor %}
          </div>
          <div class="field-error" style="margin-top:.5rem;">{{ form_errors(formUser.roles) }}</div>
        </div>

        {# ── Entreprises ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-domain"></i> Entreprises affiliées
          </div>
          <div class="checkbox-grid">
            {% for entreprise in formUser.entreprise %}
              <label class="checkbox-item">
                {{ form_widget(entreprise) }}
                <span>{{ entreprise.vars.label }}</span>
              </label>
            {% endfor %}
          </div>
          <div class="field-error" style="margin-top:.5rem;">{{ form_errors(formUser.entreprise) }}</div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_users') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ userId is not null ? 'content-save' : 'account-plus' }}"></i>
          {{ userId is not null ? 'Enregistrer les modifications' : "Créer l'utilisateur" }}
        </button>
      </div>

      {{ form_end(formUser) }}
    </div>
  </div>
{% endblock %}
