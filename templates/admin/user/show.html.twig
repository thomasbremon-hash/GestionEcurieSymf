{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  {{ user.prenom }} {{ user.nom }} | Admin
{% endblock %}

{% block body %}
  <div class="admin-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_users') }}">Utilisateurs</a>
      <span class="sep">›</span>
      <span class="current">{{ user.prenom }} {{ user.nom }}</span>
    </div>

    {# ── Hero Header ── #}
    <div class="hero-header">
      <div>
        <h1 class="hero-title">{{ user.prenom }} {{ user.nom }}</h1>
        <div class="hero-meta">
          <span class="tag tag-neutral">ID #{{ user.id }}</span>
          <span class="tag tag-accent">
            <i class="bi bi-shield-fill"></i>
            {{ user.roles|length }} rôle{{ (user.roles|length) > 1 ? 's' }}
          </span>
          <span class="tag tag-green">
            <i class="bi bi-building"></i>
            {{ user.entreprise|length }} entreprise{{ (user.entreprise|length) > 1 ? 's' }}
          </span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="{{ path('app_admin_user_update', { id: user.id }) }}" class="btn-primary-custom"><i class="bi bi-pencil-fill"></i> Modifier</a>
        <a href="{{ path('app_admin_users') }}" class="btn-ghost"><i class="bi bi-arrow-left"></i> Retour</a>
      </div>
    </div>

    {# ── KPIs ── #}
    <div class="kpi-row">
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-accent">
          <i class="bi bi-shield-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Rôles</div>
          <div class="kpi-value">{{ user.roles|length }}</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-green">
          <i class="bi bi-building"></i>
        </div>
        <div>
          <div class="kpi-label">Entreprises</div>
          <div class="kpi-value">{{ user.entreprise|length }}</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-accent">
          <i class="bi bi-heart-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Chevaux</div>
          <div class="kpi-value">{{ user.chevalProprietaires|length }}</div>
        </div>
      </div>
    </div>

    {# ── Informations personnelles ── #}
    <div class="section-card">
      <div class="section-header">
        <div class="section-icon">
          <i class="bi bi-person-fill"></i>
        </div>
        <h4 class="section-title">Informations personnelles</h4>
      </div>

      <div class="info-grid">
        <div class="info-field">
          <div class="info-label">Nom</div>
          <div class="info-value">{{ user.nom }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">Prénom</div>
          <div class="info-value">{{ user.prenom }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">Email</div>
          <div class="info-value">{{ user.email }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">Rôles</div>
          <div class="info-value">
            {% for role in user.roles %}
              <span class="role-badge">{{ role|replace({ ROLE_: '' }) }}</span>
            {% endfor %}
          </div>
        </div>

        <div class="info-divider"></div>

        <div class="info-field">
          <div class="info-label">Adresse</div>
          <div class="info-value">{{ user.rue }}, {{ user.cp }} {{ user.ville }}, {{ user.pays }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">Date de création</div>
          <div class="info-value {% if not user.createdAt %}{% endif %}">{{ user.createdAt ? user.createdAt|date('d M Y') : 'Non renseigné' }}</div>
        </div>
      </div>
    </div>

    {# ── Entreprises ── #}
    <div class="section-card">
      <div class="section-header">
        <div class="section-icon">
          <i class="bi bi-building"></i>
        </div>
        <h4 class="section-title">Entreprises affiliées</h4>
      </div>

      {% if (user.entreprise|length) > 0 %}
        <div class="entities-grid">
          {% for entreprise in user.entreprise %}
            <div class="entity-card">
              <div class="entity-avatar">{{ entreprise.nom|slice(0, 1)|upper }}</div>
              <div class="entity-name" title="{{ entreprise.nom }}">{{ entreprise.nom }}</div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="bi bi-building-slash" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;opacity:0.4"></i>
          Aucune entreprise affiliée.
        </div>
      {% endif %}
    </div>

    {# ── Chevaux ── #}
    <div class="section-card">
      <div class="section-header">
        <div class="section-icon">
          <i class="bi bi-heart-fill"></i>
        </div>
        <h4 class="section-title">Chevaux possédés</h4>
      </div>

      {% if (user.chevalProprietaires|length) > 0 %}
        <div class="entities-grid">
          {% for cp in user.chevalProprietaires %}
            <div class="entity-card">
              <div class="entity-avatar">{{ cp.cheval.nom|slice(0, 1)|upper }}</div>
              <div class="entity-name" title="{{ cp.cheval.nom }}">{{ cp.cheval.nom }}</div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="bi bi-heartbreak" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;opacity:0.4"></i>
          Aucun cheval possédé.
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
