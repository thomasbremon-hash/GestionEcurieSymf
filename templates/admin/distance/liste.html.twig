{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | Liste des distances
{% endblock %}

{% block body %}
  <div class="admin-wrapper--wide">
    {# ── Flash ── #}
    {% for label, messages in app.flashes(['success', 'danger']) %}
      {% for message in messages %}
        <div class="flash {{ label }}">
          <span><i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i> {{ message }}</span>
          <button class="flash-close" onclick="this.parentElement.remove()"><i class="mdi mdi-close"></i></button>
        </div>
      {% endfor %}
    {% endfor %}

    {# ── Page top ── #}
    <div class="page-top">
      <div>
        <div class="page-eyebrow">Admin › Gestion</div>
        <h1 class="page-title">Distances <span class="subtitle">{{ distances|length }} au total</span></h1>
      </div>
      <a href="{{ path('app_admin_distance_new') }}" class="btn-primary-custom"><i class="mdi mdi-plus"></i> Ajouter une distance</a>
    </div>

    {# ── Table card ── #}
    <div class="table-card">
      <div class="table-card-header">
        <div class="table-card-header-left">
          <div class="table-card-title">
            <i class="mdi mdi-map-marker-distance" style="color:var(--blue)"></i>
            Liste des distances
            <span class="count-badge">{{ distances|length }}</span>
          </div>
          <div class="per-page-wrap">
            Afficher<select id="per-page-select">
              <option value="10">10</option>
              <option value="25" selected>25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>par page
          </div>
        </div>
        <div class="search-wrap">
          <i class="mdi mdi-magnify search-icon"></i>
          <input type="text" id="search-input" placeholder="Rechercher…" />
        </div>
      </div>

      <table class="data-table">
        <thead>
          <tr>
            <th>Distance</th>
            <th>Entreprise</th>
            <th>Structure</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="distance-tbody">
          {% for item in distances %}
            <tr data-index="{{ loop.index0 }}">
              {# Distance #}
              <td>
                <span class="pill tag-accent" style="font-family:'Sora',sans-serif;font-weight:700;">
                  <i class="mdi mdi-map-marker-distance"></i>
                  {{ item.distance }} km
                </span>
              </td>

              {# Entreprise #}
              <td>
                {% if item.entreprise %}
                  <span class="pill pill-user">
                    <i class="mdi mdi-domain"></i>
                    {{ item.entreprise.nom }}
                  </span>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;">—</span>
                {% endif %}
              </td>

              {# Structure #}
              <td>
                {% if item.structure %}
                  <span class="pill" style="background:var(--gold-light);color:var(--gold);border:1px solid rgba(160,124,48,.2);">
                    <i class="mdi mdi-office-building-outline"></i>
                    {{ item.structure.nom }}
                  </span>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;">—</span>
                {% endif %}
              </td>

              {# Actions #}
              <td>
                <div class="action-btns">
                  <a href="{{ path('app_admin_distance_update', { id: item.id }) }}" class="action-btn edit" title="Modifier"><i class="mdi mdi-pencil"></i></a>
                  <button class="action-btn del" onclick="openModal('modal-{{ item.id }}')" title="Supprimer"><i class="mdi mdi-trash-can"></i></button>
                </div>
              </td>
            </tr>
          {% else %}
            <tr class="empty-row">
              <td colspan="4">
                <i class="mdi mdi-map-marker-off-outline" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.35"></i>
                Aucune distance trouvée.
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="table-footer">
        <div class="pagination-info" id="pagination-info">—</div>
        <div class="pagination-controls" id="pagination-controls"></div>
      </div>
    </div>
  </div>

  {# ── Modals suppression ── #}
  {% for item in distances %}
    <div class="modal-overlay" id="modal-{{ item.id }}">
      <div class="modal-box">
        <div class="modal-icon">
          <i class="mdi mdi-trash-can-outline"></i>
        </div>
        <div class="modal-title">Supprimer cette distance ?</div>
        <div class="modal-text">
          Vous êtes sur le point de supprimer la distance de <strong>{{ item.distance }} km</strong>
          {% if item.entreprise %}
            entre <strong>{{ item.entreprise.nom }}</strong>
          {% endif %}
          {% if item.structure %}
            et <strong>{{ item.structure.nom }}</strong>
          {% endif %}.<br />
          Cette action est irréversible.
        </div>
        <div class="modal-actions">
          <button class="btn-ghost" onclick="closeModal('modal-{{ item.id }}')">Annuler</button>
          <a href="{{ path('app_admin_distance_delete', { id: item.id }) }}" class="btn-danger"><i class="mdi mdi-trash-can"></i> Supprimer</a>
        </div>
      </div>
    </div>
  {% endfor %}
{% endblock %}
