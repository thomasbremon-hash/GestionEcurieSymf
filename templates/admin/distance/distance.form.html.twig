{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ distanceId is not null ? 'Modifier une distance' : 'Ajouter une distance' }}
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_distances') }}">Distances</a>
      <span class="sep">›</span>
      <span class="current">{{ distanceId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Distances</div>
        <h1 class="page-title">{{ distanceId is not null ? 'Modifier la distance' : 'Ajouter une distance' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon" style="background:var(--blue-light);color:var(--blue);">
          <i class="mdi mdi-map-marker-distance"></i>
        </div>
        <h2 class="form-card-title">{{ distanceId is not null ? 'Modifier les informations' : 'Nouvelle distance' }}</h2>
      </div>

      {{ form_start(formDistance, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Localisation ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-domain"></i> Localisation
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formDistance.entreprise) }}
              {{ form_widget(formDistance.entreprise) }}
              <div class="field-error">{{ form_errors(formDistance.entreprise) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formDistance.structure) }}
              {{ form_widget(formDistance.structure) }}
              <div class="field-error">{{ form_errors(formDistance.structure) }}</div>
            </div>
          </div>
        </div>

        {# ── Distance ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-map-marker-distance"></i> Distance
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formDistance.distance) }}
              {{ form_widget(formDistance.distance) }}
              <div class="field-error">{{ form_errors(formDistance.distance) }}</div>
              <p style="font-size:0.78rem;color:var(--ink-muted);margin-top:0.35rem;">
                <i class="mdi mdi-information-outline"></i> Distance en kilomètres
              </p>
            </div>
          </div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_distances') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ distanceId is not null ? 'content-save' : 'plus-circle' }}"></i>
          {{ distanceId is not null ? 'Enregistrer les modifications' : 'Ajouter la distance' }}
        </button>
      </div>

      {{ form_end(formDistance) }}
    </div>
  </div>
{% endblock %}
