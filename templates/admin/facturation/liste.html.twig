{% extends 'layouts/base.admin.html.twig' %}
{% block title %}BackOffice | Facturation utilisateurs
{% endblock %}
{% block body %}
<div class="admin-wrapper--wide">
	{% for label, messages in app.flashes(['success', 'danger']) %}
		{% for message in messages %}
			<div class="flash {{ label }}">
				<span>
					<i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i>
					{{ message }}</span>
				<button class="flash-close" onclick="this.parentElement.remove()">
					<i class="mdi mdi-close"></i>
				</button>
			</div>
		{% endfor %}
	{% endfor %}

	<div class="page-top">
		<div>
			<div class="page-eyebrow"><a href="{{ path('app_admin') }}">Dashboard</a> › <span>Facturation</span></div>
			<h1 class="page-title">Facturation
				<span class="subtitle">{{ factures|length }}
					document{{ factures|length > 1 ? 's' }}</span>
			</h1>
		</div>
		{% if is_granted('ROLE_ADMIN') %}
			<a href="{{ path('app_admin_facturation_generer_utilisateur') }}" class="btn-primary-custom">
				<i class="mdi mdi-plus"></i>
				Générer des factures
			</a>
		{% endif %}
	</div>

	{% set currentEntreprise = null %}
	{% set currentMonth = null %}

	{% for facture in factures %}
		{% set entrepriseNom = facture.entreprise.nom %}
		{% set monthYear = ('%02d'|format(facture.moisDeGestion.mois)) ~ '/' ~ facture.moisDeGestion.annee %}

		{% if currentEntreprise != entrepriseNom %}
			{% if currentEntreprise is not null %}
			</tbody>
		</table>
		<div class="table-footer">
			<div class="pagination-info"></div>
		</div>
	</div>
</div>{% endif %}<div class="entreprise-block">
<div class="entreprise-block-header">
	<div class="user-avatar" style="width:40px;height:40px;font-size:0.9rem;background:var(--accent);border-radius:var(--radius-sm);">
		{{ entrepriseNom|slice(0,1)|upper }}
	</div>
	<div>
		<div class="entreprise-block-name">{{ entrepriseNom }}</div>
		<div class="entreprise-block-sub">
			{% set nb = 0 %}
			{% for f in factures %}
				{% if f.entreprise.nom == entrepriseNom %}
					{% set nb = nb + 1 %}
				{% endif %}
			{% endfor %}
			{{ nb }}
			facture{{ nb > 1 ? 's' }}
		</div>
	</div>
</div>

<div class="table-card">
	<table class="data-table">
		<thead>
			<tr>
				<th>Mois</th>
				<th>Client</th>
				<th>N° / Type</th>
				<th>Total TTC</th>
				<th>Statut</th>
				<th>Email</th>
				<th style="text-align:right">Actions</th>
			</tr>
		</thead>
		<tbody>
			{% set currentEntreprise = entrepriseNom %}
			{% set currentMonth = null %}
		{% endif %}

		{% if currentMonth != monthYear %}
			<tr class="month-separator-row">
				<td colspan="7">
					<span class="month-separator-label">
						<i class="mdi mdi-calendar-month"></i>
						{{ monthYear }}</span>
				</td>
			</tr>
			{% set currentMonth = monthYear %}
		{% endif %}

		<tr>
			<td>
				<span class="tag-neutral tag" style="font-size:0.75rem;">{{ monthYear }}</span>
			</td>
			<td>
				<div class="user-cell">
					<div class="user-avatar" style="width:34px;height:34px;font-size:0.75rem;">
						{{ facture.utilisateur.nom|slice(0,1)|upper }}{{ facture.utilisateur.prenom|slice(0,1)|upper }}
					</div>
					<div class="user-name">{{ facture.utilisateur.nom }}
						{{ facture.utilisateur.prenom }}</div>
				</div>
			</td>
			<td>
				<div style="display:flex;flex-direction:column;gap:0.25rem;">
					<span class="invoice-num">{{ facture.numFacture }}</span>
					{% if facture.type == 'avoir' %}
						<span class="pill pill-avoir" style="font-size:0.7rem;padding:0.1rem 0.5rem;width:fit-content;">Avoir</span>
						{% if facture.factureOrigine %}
							<span style="font-size:0.72rem;color:var(--ink-muted);">Annule {{ facture.factureOrigine.numFacture }}</span>
						{% endif %}
					{% endif %}
				</div>
			</td>
			<td>
				{% if facture.type == 'avoir' %}
					<span class="amount-cell" style="color:var(--red);">-{{ (facture.total|abs)|number_format(2, ',', ' ') }} €</span>
				{% else %}
					<span class="amount-cell">{{ totauxTtc[facture.id]|number_format(2, ',', ' ') }} €</span>
				{% endif %}
			</td>
			<td>
				{% if facture.statut == 'payee' %}
					<span class="pill pill-active">
						<i class="mdi mdi-check-circle"></i>
						Payée</span>
				{% elseif facture.statut == 'annulee' %}
					<span class="pill pill-annulee">
						<i class="mdi mdi-cancel"></i>
						Annulée</span>
				{% elseif facture.statut == 'impayee' %}
					<span class="pill pill-admin">
						<i class="mdi mdi-alert-circle"></i>
						Impayée</span>
				{% else %}
					<span class="pill pill-pending">
						<i class="mdi mdi-clock-outline"></i>
						En attente</span>
				{% endif %}
			</td>
			<td>
				{% if facture.mailEnvoye %}
					<span class="pill pill-active">
						<i class="mdi mdi-email-check"></i>
						Envoyé</span>
				{% else %}
					<span class="pill pill-pending">
						<i class="mdi mdi-email-outline"></i>
						Non envoyé</span>
				{% endif %}
			</td>
			<td>
				<div
					class="action-btns">
					{# Voir / Télécharger PDF — visible par tous #}
					<a href="{{ path('app_admin_facturation_voir_utilisateur', {id: facture.id}) }}" class="action-btn" style="color:var(--sidebar-accent);border-color:rgba(79,128,196,0.3);background:rgba(79,128,196,0.08);" title="Voir la facture" target="_blank">
						<i class="mdi mdi-eye"></i>
					</a>
					<a href="{{ path('app_admin_facturation_pdf_utilisateur', {id: facture.id}) }}" class="action-btn" style="color:var(--red);border-color:rgba(185,28,28,0.3);background:var(--red-light);" title="Télécharger PDF">
						<i class="mdi mdi-file-pdf-box"></i>
					</a>
					{% if facture.type == 'facture' %}
						<a href="{{ path('app_admin_facturation_facturx', {id: facture.id}) }}" class="action-btn" style="color:#16a34a;border-color:rgba(22,163,74,0.3);background:rgba(22,163,74,0.08);" title="Télécharger Factur-X (XML)">
							<i class="mdi mdi-xml"></i>
						</a>
					{% endif %}

					{% if is_granted('ROLE_ADMIN') %}
						{% if facture.type == 'facture' and not facture.mailEnvoye and facture.statut != 'annulee' %}
							<a href="{{ path('app_admin_facturation_edit', {id: facture.id}) }}" class="action-btn" style="color:var(--sidebar-accent);border-color:rgba(79,128,196,0.3);background:rgba(79,128,196,0.08);" title="Modifier">
								<i class="mdi mdi-pencil"></i>
							</a>
						{% endif %}
						{% if facture.type == 'facture' and facture.mailEnvoye and facture.statut != 'annulee' %}
							<a href="{{ path('app_admin_facturation_corriger', {id: facture.id}) }}" class="action-btn" style="color:var(--red);border-color:rgba(185,28,28,0.3);background:var(--red-light);" title="Corriger (avoir)">
								<i class="mdi mdi-file-replace-outline"></i>
							</a>
						{% endif %}
						{% if facture.statut == 'impayee' and facture.type != 'avoir' %}
							<a href="{{ path('app_admin_facturation_payer', {id: facture.id}) }}" class="action-btn" style="color:var(--green);border-color:rgba(61,107,82,0.3);background:var(--green-light);" title="Marquer payée">
								<i class="mdi mdi-cash-plus"></i>
							</a>
						{% endif %}
						{% if not facture.mailEnvoye and facture.type == 'facture' and facture.statut != 'annulee' %}
							<a href="{{ path('app_admin_facturation_envoyer_mail', {id: facture.id}) }}" class="action-btn" style="color:var(--gold);border-color:rgba(160,124,48,0.3);background:var(--gold-light);" title="Envoyer le mail">
								<i class="mdi mdi-email-send"></i>
							</a>
						{% endif %}
					{% endif %}
				</div>
			</td>
		</tr>
	{% endfor %}

	{% if currentEntreprise is not null %}
	</tbody>
</table>
<div class="table-footer">
	<div class="pagination-info"></div>
</div></div></div>{% endif %}</div>{% endblock %}
