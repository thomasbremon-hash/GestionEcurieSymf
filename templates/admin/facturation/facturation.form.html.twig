{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | Générer des factures utilisateurs
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_facturation_utilisateur') }}">Facturation</a>
      <span class="sep">›</span>
      <span class="current">Générer</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Gestion financière</div>
        <h1 class="page-title">Générer des factures</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon">
          <i class="mdi mdi-account-cash"></i>
        </div>
        <h2 class="form-card-title">Paramètres de génération</h2>
      </div>

      {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-tune"></i> Sélection
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(form.moisDeGestion) }}
              {{ form_widget(form.moisDeGestion) }}
              <div class="field-error">{{ form_errors(form.moisDeGestion) }}</div>
            </div>

            <div class="form-field">
              {{ form_label(form.entreprise) }}
              {{ form_widget(form.entreprise) }}
              <div class="field-error">{{ form_errors(form.entreprise) }}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="form-footer">
        <a href="{{ path('app_admin_facturation_utilisateur') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom"><i class="mdi mdi-file-document-multiple"></i> Générer les factures</button>
      </div>

      {{ form_end(form) }}
    </div>
  </div>
{% endblock %}
