<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: DejaVu Sans, sans-serif;
        font-size: 8.5px;
        color: #1a1714;
        background: #fff;
        padding: 24px 28px;
        line-height: 1.35;
      }
      
      /* ════ EN-TÊTE ════ */
      .header {
        display: table;
        width: 100%;
        margin-bottom: 14px;
      }
      .header-left {
        display: table-cell;
        vertical-align: middle;
        width: 50%;
      }
      .header-right {
        display: table-cell;
        vertical-align: middle;
        width: 50%;
        text-align: right;
      }
      
      .logo {
        height: 38px;
        display: block;
        margin-bottom: 5px;
      }
      
      .company-name {
        font-size: 13px;
        font-weight: bold;
        color: #1f2937;
        letter-spacing: -0.3px;
      }
      .company-sub {
        font-size: 7.5px;
        color: #a09b96;
        margin-top: 1px;
      }
      
      .invoice-label {
        font-size: 7px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #a09b96;
        margin-bottom: 2px;
      }
      .invoice-num {
        font-size: 15px;
        font-weight: bold;
        color: #1f2937;
        letter-spacing: -0.5px;
      }
      .invoice-meta {
        font-size: 7.5px;
        color: #6b6560;
        margin-top: 2px;
      }
      
      .statut-pill {
        display: inline-block;
        padding: 2px 7px;
        border-radius: 20px;
        font-size: 7px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 3px;
      }
      .paid {
        background: #d1fae5;
        color: #065f46;
      }
      .unpaid {
        background: #fee2e2;
        color: #991b1b;
      }
      
      /* ════ BARRE DE SÉPARATION ════ */
      .divider {
        height: 2px;
        background: #1f2937;
        margin-bottom: 12px;
        border-radius: 1px;
      }
      
      /* ════ INFOS 3 COLONNES ════ */
      .meta-row {
        display: table;
        width: 100%;
        margin-bottom: 14px;
        background: #f7f6f3;
        border-radius: 4px;
      }
      .meta-cell {
        display: table-cell;
        padding: 8px 10px;
        vertical-align: top;
        width: 33.33%;
        border-right: 1px solid #e8e5e0;
      }
      .meta-cell:last-child {
        border-right: none;
      }
      .meta-label {
        font-size: 6.5px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #a09b96;
        font-weight: bold;
        margin-bottom: 3px;
      }
      .meta-value {
        font-size: 8.5px;
        font-weight: bold;
        color: #1a1714;
      }
      .meta-sub {
        font-size: 7.5px;
        color: #6b6560;
        margin-top: 1px;
        line-height: 1.5;
      }
      
      /* ════ TABLEAU ════ */
      table.lignes {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
      }
      table.lignes thead tr {
        background: #1f2937;
      }
      table.lignes thead th {
        color: #fff;
        padding: 5px 7px;
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        font-weight: bold;
        text-align: left;
      }
      table.lignes thead th.r {
        text-align: right;
      }
      table.lignes thead th.c {
        text-align: center;
      }
      
      table.lignes tbody tr {
        border-bottom: 1px solid #f0ede8;
      }
      table.lignes tbody tr:last-child {
        border-bottom: none;
      }
      table.lignes tbody td {
        padding: 4px 7px;
        font-size: 8px;
        color: #1a1714;
        vertical-align: middle;
      }
      table.lignes tbody td.r {
        text-align: right;
      }
      table.lignes tbody td.c {
        text-align: center;
        color: #6b6560;
      }
      
      .cheval-row td {
        background: #eef0f5;
        font-weight: bold;
        font-size: 7.5px;
        color: #1f2937;
        padding: 3px 7px;
        border-top: 1px solid #ddd;
        border-bottom: none !important;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }
      
      /* ════ TOTAUX ════ */
      .bottom-row {
        display: table;
        width: 100%;
        margin-bottom: 12px;
      }
      .bottom-left {
        display: table-cell;
        width: 52%;
        vertical-align: bottom;
      }
      .bottom-right {
        display: table-cell;
        width: 48%;
        vertical-align: top;
      }
      
      .note-box {
        background: #f7f6f3;
        border-left: 2px solid #1f2937;
        padding: 6px 8px;
        font-size: 7.5px;
        color: #6b6560;
        line-height: 1.6;
        border-radius: 0 3px 3px 0;
      }
      
      table.totaux {
        width: 100%;
        border-collapse: collapse;
      }
      table.totaux td {
        padding: 3px 7px;
        font-size: 8px;
        border-bottom: 1px solid #f0ede8;
      }
      table.totaux td.r {
        text-align: right;
        font-weight: bold;
      }
      table.totaux tr:last-child td {
        border-bottom: none;
      }
      
      .ttc-row td {
        background: #1f2937 !important;
        color: #fff !important;
        font-size: 10px !important;
        font-weight: bold !important;
        padding: 6px 8px !important;
        border: none !important;
      }
      .ttc-row td.r {
        text-align: right;
      }
      
      /* ════ FOOTER ════ */
      .footer {
        border-top: 1px solid #e3dfd8;
        padding-top: 7px;
        display: table;
        width: 100%;
      }
      .footer-left {
        display: table-cell;
        width: 65%;
        font-size: 7px;
        color: #b0aaa4;
        line-height: 1.7;
        vertical-align: bottom;
      }
      .footer-right {
        display: table-cell;
        width: 35%;
        text-align: right;
        font-size: 7px;
        color: #6b6560;
        vertical-align: bottom;
        line-height: 1.7;
      }
    </style>
  </head>
  <body>
    {# ── En-tête ── #}
    <div class="header">
      <div class="header-left">
        <img src="assets/img/logopdf.png" class="logo" />
        <div class="company-name">{{ facture.entreprise.nom }}</div>
        <div class="company-sub">{{ facture.entreprise.rue }} — {{ facture.entreprise.cp }} {{ facture.entreprise.ville }}</div>
      </div>
      <div class="header-right">
        <div class="invoice-label">Facture</div>
        <div class="invoice-num">{{ facture.numFacture }}</div>
        <div class="invoice-meta">Période {{ '%02d'|format(mois.mois) }}/{{ mois.annee }} · Édité le {{ 'now'|date('d/m/Y') }}</div>
        <div>
          <span class="statut-pill {{ facture.statut != 'impayee' ? 'paid' : 'unpaid' }}">{{ facture.statut != 'impayee' ? '✓ Réglé' : '⏱ En attente' }}</span>
        </div>
      </div>
    </div>

    <div class="divider"></div>

    {# ── Bloc infos 3 colonnes ── #}
    <div class="meta-row">
      <div class="meta-cell">
        <div class="meta-label">Émetteur</div>
        <div class="meta-value">{{ facture.entreprise.nom }}</div>
        <div class="meta-sub">
          SIRET : {{ facture.entreprise.siret }}<br />
          {% if facture.entreprise.numTVA %}
            TVA : {{ facture.entreprise.numTVA }}<br />
          {% endif %}
          {{ facture.entreprise.telephone ?? '' }}
        </div>
      </div>
      <div class="meta-cell">
        <div class="meta-label">Facturé à</div>
        <div class="meta-value">{{ user.prenom }} {{ user.nom }}</div>
        <div class="meta-sub">
          {{ user.email }}<br />
          {{ user.rue }}<br />
          {{ user.cp }} {{ user.ville }}
        </div>
      </div>
      <div class="meta-cell">
        <div class="meta-label">Détails</div>
        <div class="meta-sub">
          <strong>Période :</strong> {{ '%02d'|format(mois.mois) }}/{{ mois.annee }}<br />
          <strong>N° :</strong> {{ facture.numFacture }}<br />
          <strong>Échéance :</strong> 30 jours<br />
          <strong>Statut :</strong> {{ facture.statut != 'impayee' ? 'Réglé' : 'En attente' }}
        </div>
      </div>
    </div>

    {# ── Tableau des lignes ── #}
    <table class="lignes">
      <thead>
        <tr>
          <th>Désignation</th>
          <th class="c">Qté</th>
          <th class="r">PU HT</th>
          <th class="r">HT</th>
          <th class="c">TVA</th>
          <th class="r">TVA €</th>
        </tr>
      </thead>
      <tbody>
        {% for cheval, lignes in lignesParCheval %}
          <tr class="cheval-row">
            <td colspan="6">{{ cheval }} — {{ lignes[0].pourcentage }} %</td>
          </tr>
          {% for ligne in lignes %}
            <tr>
              <td style="padding-left:14px;">{{ ligne.description }}</td>
              <td class="c">{{ ligne.quantite }}</td>
              <td class="r">{{ ligne.prixUnitaire|number_format(2, ',', ' ') }} €</td>
              <td class="r">{{ ligne.montantHT|number_format(2, ',', ' ') }} €</td>
              <td class="c">{{ ligne.tauxTVA }} %</td>
              <td class="r">{{ ligne.montantTVA|number_format(2, ',', ' ') }} €</td>
            </tr>
          {% endfor %}
        {% endfor %}
      </tbody>
    </table>

    {# ── Bas de page : note + totaux ── #}
    <div class="bottom-row">
      <div class="bottom-left">
        <div class="note-box">
          <strong>Conditions de paiement :</strong> 30 jours nets<br />
          Pénalités de retard : taux légal en vigueur<br />
          Indemnité forfaitaire : 40 € — TVA non applicable art. 293B CGI (si applicable)
        </div>
      </div>
      <div class="bottom-right">
        <table class="totaux">
          <tbody>
            <tr>
              <td>Total HT</td>
              <td class="r">{{ totalHT|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% for taux, montant in totalTVA %}
              <tr>
                <td>TVA {{ taux }} %</td>
                <td class="r">{{ montant|number_format(2, ',', ' ') }} €</td>
              </tr>
            {% endfor %}
            <tr class="ttc-row">
              <td>Total TTC</td>
              <td class="r">{{ totalTTC|number_format(2, ',', ' ') }} €</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {# ── Footer ── #}
    <div class="footer">
      <div class="footer-left">
        {{ facture.entreprise.nom }} · SIRET {{ facture.entreprise.siret }}
        {% if facture.entreprise.numTVA %}
          · TVA {{ facture.entreprise.numTVA }}
        {% endif %}· {{ facture.entreprise.rue }}, {{ facture.entreprise.cp }} {{ facture.entreprise.ville }}
      </div>
      <div class="footer-right">Document généré le {{ 'now'|date('d/m/Y à H:i') }}</div>
    </div>
  </body>
</html>
