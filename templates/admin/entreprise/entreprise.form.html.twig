{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ entrepriseId is not null ? 'Modifier' : 'Ajouter' }} une entreprise
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_entreprises') }}">Entreprises</a>
      <span class="sep">›</span>
      <span class="current">{{ entrepriseId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Entreprises</div>
        <h1 class="page-title">{{ entrepriseId is not null ? "Modifier l'entreprise" : 'Ajouter une entreprise' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon">
          <i class="mdi mdi-{{ entrepriseId is not null ? 'office-building-cog' : 'office-building-plus' }}"></i>
        </div>
        <h2 class="form-card-title">{{ entrepriseId is not null ? 'Modifier les informations' : 'Nouvelle entreprise' }}</h2>
      </div>

      {{ form_start(formEntreprise, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Identité ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-domain"></i> Identité
          </div>
          <div class="fields-row cols-1">
            <div class="form-field">
              {{ form_label(formEntreprise.nom) }}
              {{ form_widget(formEntreprise.nom) }}
              <div class="field-error">{{ form_errors(formEntreprise.nom) }}</div>
            </div>
          </div>
        </div>

        {# ── Coordonnées ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-phone-outline"></i> Coordonnées
          </div>
          <div class="fields-row cols-1">
            <div class="form-field">
              {{ form_label(formEntreprise.telephone) }}
              {{ form_widget(formEntreprise.telephone) }}
              <div class="field-error">{{ form_errors(formEntreprise.telephone) }}</div>
            </div>
          </div>
          <div class="fields-row cols-1" style="margin-top:1.25rem;">
            <div class="form-field">
              {{ form_label(formEntreprise.email) }}
              {{ form_widget(formEntreprise.email) }}
              <div class="field-error">{{ form_errors(formEntreprise.email) }}</div>
            </div>
          </div>
        </div>

        {# ── Adresse ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-map-marker-outline"></i> Adresse
          </div>
          <div class="fields-row cols-1" style="margin-bottom:1.25rem;">
            <div class="form-field">
              {{ form_label(formEntreprise.rue) }}
              {{ form_widget(formEntreprise.rue) }}
              <div class="field-error">{{ form_errors(formEntreprise.rue) }}</div>
            </div>
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formEntreprise.ville) }}
              {{ form_widget(formEntreprise.ville) }}
              <div class="field-error">{{ form_errors(formEntreprise.ville) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formEntreprise.cp) }}
              {{ form_widget(formEntreprise.cp) }}
              <div class="field-error">{{ form_errors(formEntreprise.cp) }}</div>
            </div>
          </div>
          <div class="fields-row cols-1" style="margin-top:1.25rem;">
            <div class="form-field">
              {{ form_label(formEntreprise.pays) }}
              {{ form_widget(formEntreprise.pays) }}
              <div class="field-error">{{ form_errors(formEntreprise.pays) }}</div>
            </div>
          </div>
        </div>

        {# ── Informations légales ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-file-document-outline"></i> Informations légales
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formEntreprise.siren) }}
              {{ form_widget(formEntreprise.siren) }}
              <div class="field-error">{{ form_errors(formEntreprise.siren) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formEntreprise.siret) }}
              {{ form_widget(formEntreprise.siret) }}
              <div class="field-error">{{ form_errors(formEntreprise.siret) }}</div>
            </div>
          </div>
          {% if formEntreprise.numTVA is defined %}
            <div class="fields-row cols-1" style="margin-top:1.25rem;">
              <div class="form-field">
                {{ form_label(formEntreprise.numTVA) }}
                {{ form_widget(formEntreprise.numTVA) }}
                <div class="field-error">{{ form_errors(formEntreprise.numTVA) }}</div>
              </div>
            </div>
          {% endif %}
          <div class="fields-row cols-1" style="margin-top:1.25rem;">
            <div class="form-field">
              {{ form_label(formEntreprise.codeAPE) }}
              {{ form_widget(formEntreprise.codeAPE) }}
              <div class="field-error">{{ form_errors(formEntreprise.codeAPE) }}</div>
            </div>
          </div>
        </div>

        {# ── Coordonnées bancaires ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-bank-outline"></i> Coordonnées bancaires
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formEntreprise.iban) }}
              {{ form_widget(formEntreprise.iban) }}
              <div class="field-error">{{ form_errors(formEntreprise.iban) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formEntreprise.bic) }}
              {{ form_widget(formEntreprise.bic) }}
              <div class="field-error">{{ form_errors(formEntreprise.bic) }}</div>
            </div>
          </div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_entreprises') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ entrepriseId is not null ? 'content-save' : 'office-building-plus' }}"></i>
          {{ entrepriseId is not null ? 'Enregistrer les modifications' : "Créer l'entreprise" }}
        </button>
      </div>

      {{ form_end(formEntreprise) }}
    </div>
  </div>
{% endblock %}
