{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  {{ entreprise.nom }} | Admin
{% endblock %}

{% block body %}
  <div class="admin-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_entreprises') }}">Entreprises</a>
      <span class="sep">›</span>
      <span class="current">{{ entreprise.nom }}</span>
    </div>

    {# ── Hero Header ── #}
    <div class="hero-header">
      <div>
        <h1 class="hero-title">{{ entreprise.nom }}</h1>
        <div class="hero-meta">
          <span class="tag tag-neutral">ID #{{ entreprise.id }}</span>
          <span class="tag tag-accent">
            <i class="bi bi-people-fill"></i>
            {{ entreprise.users|length }} utilisateur{{ (entreprise.users|length) > 1 ? 's' }}
          </span>
          <span class="tag tag-green">
            <i class="bi bi-heart-fill"></i>
            {{ entreprise.cheval|length }} cheval{{ (entreprise.cheval|length) > 1 ? 'aux' }}
          </span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="{{ path('app_admin_entreprise_update', { id: entreprise.id }) }}" class="btn-primary-custom"><i class="bi bi-pencil-fill"></i> Modifier</a>
        <a href="{{ path('app_admin_entreprises') }}" class="btn-ghost"><i class="bi bi-arrow-left"></i> Retour</a>
      </div>
    </div>

    {# ── KPIs ── #}
    <div class="kpi-row">
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-orange">
          <i class="bi bi-people-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Utilisateurs</div>
          <div class="kpi-value">{{ entreprise.users|length }}</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-green">
          <i class="bi bi-heart-fill"></i>
        </div>
        <div>
          <div class="kpi-label">Chevaux</div>
          <div class="kpi-value">{{ entreprise.cheval|length }}</div>
        </div>
      </div>
    </div>

    {# ── Informations générales ── #}
    <div class="section-card">
      <div class="section-header">
        <div class="section-icon">
          <i class="bi bi-building"></i>
        </div>
        <h4 class="section-title">Informations générales</h4>
      </div>

      <div class="info-grid">
        <div class="info-field">
          <div class="info-label">Adresse</div>
          <div class="info-value">
            {{ entreprise.adresseComplete }}<br />{{ entreprise.pays }}
          </div>
        </div>

        <div class="info-field">
          <div class="info-label">Téléphone</div>
          <div class="info-value {% if not entreprise.telephone %}{% endif %}">{{ entreprise.telephone ? : 'Non renseigné' }}</div>
        </div>

        <div class="info-divider"></div>

        <div class="info-field">
          <div class="info-label">SIREN</div>
          <div class="info-value {% if not entreprise.siren %}{% endif %}">{{ entreprise.siren ? : 'Non renseigné' }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">SIRET</div>
          <div class="info-value {% if not entreprise.siret %}{% endif %}">{{ entreprise.siret ? : 'Non renseigné' }}</div>
        </div>

        <div class="info-field">
          <div class="info-label">Numéro TVA</div>
          <div class="info-value {% if not entreprise.numTVA %}{% endif %}">{{ entreprise.numTVA ? : 'Non renseigné' }}</div>
        </div>
      </div>
    </div>

    {# ── Utilisateurs ── #}
    <div class="section-card">
      <div class="section-header">
        <div class="section-icon">
          <i class="bi bi-people"></i>
        </div>
        <h4 class="section-title">Utilisateurs affiliés</h4>
      </div>

      {% if (entreprise.users|length) > 0 %}
        <div class="users-grid">
          {% for user in entreprise.users %}
            <div class="user-card">
              <div class="user-avatar">{{ user.email|slice(0, 1)|upper }}</div>
              <div class="user-email" title="{{ user.email }}">{{ user.email }}</div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="bi bi-person-slash" style="font-size:1.5rem;display:block;margin-bottom:0.5rem;opacity:0.4"></i>
          Aucun utilisateur affilié.
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
