{% extends 'layouts/base.admin.html.twig' %}
{% block title %}BackOffice | Liste des structures
{% endblock %}
{% block body %}
	<div class="admin-wrapper--wide">
		{% for label, messages in app.flashes(['success', 'danger']) %}
			{% for message in messages %}
				<div class="flash {{ label }}">
					<span>
						<i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i>
						{{ message }}</span>
					<button class="flash-close" onclick="this.parentElement.remove()">
						<i class="mdi mdi-close"></i>
					</button>
				</div>
			{% endfor %}
		{% endfor %}

		<div class="page-top">
			<div>
				<div class="page-eyebrow">Admin › Gestion</div>
				<h1 class="page-title">Structures
					<span class="subtitle">{{ structures|length }}
						au total</span>
				</h1>
			</div>
			{% if is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_admin_structure_new') }}" class="btn-primary-custom">
					<i class="mdi mdi-plus"></i>
					Ajouter une structure</a>
			{% endif %}
		</div>

		<div class="table-card">
			<div class="table-card-header">
				<div class="table-card-header-left">
					<div class="table-card-title">
						<i class="mdi mdi-office-building-outline" style="color:var(--accent)"></i>
						Liste des structures
						<span class="count-badge">{{ structures|length }}</span>
					</div>
					<div class="per-page-wrap">
						Afficher<select id="per-page-select">
							<option value="10">10</option>
							<option value="25" selected>25</option>
							<option value="50">50</option>
							<option value="100">100</option>
						</select>par page
					</div>
				</div>
				<div class="search-wrap">
					<i class="mdi mdi-magnify search-icon"></i>
					<input type="text" id="search-input" placeholder="Rechercher…"/>
				</div>
			</div>

			<table class="data-table">
				<thead>
					<tr>
						<th>Nom</th>
						<th>Rue</th>
						<th>Ville</th>
						<th>Code postal</th>
						{% if is_granted('ROLE_ADMIN') %}
							<th style="text-align:right">Actions</th>
						{% endif %}
					</tr>
				</thead>
				<tbody id="structure-tbody" data-noun="structure" data-noun-plural="structures">
					{% for item in structures %}
						<tr data-index="{{ loop.index0 }}">
							<td>
								<div class="user-cell">
									<div class="user-avatar" style="background:var(--accent);">{{ item.nom|slice(0,1)|upper }}</div>
									<div class="user-name">{{ item.nom }}</div>
								</div>
							</td>
							<td>
								<span style="font-size:0.88rem;color:var(--ink-soft);">{{ item.rue ?: '—' }}</span>
							</td>
							<td>
								<span style="font-size:0.88rem;color:var(--ink-soft);">
									<i class="mdi mdi-map-marker-outline" style="color:var(--ink-muted);"></i>
									{{ item.ville ?: '—' }}</span>
							</td>
							<td>
								<span class="pill tag-neutral">{{ item.cp ?: '—' }}</span>
							</td>
							{% if is_granted('ROLE_ADMIN') %}
								<td>
									<div class="action-btns">
										<a href="{{ path('app_admin_structure_update', {id: item.id}) }}" class="action-btn edit" title="Modifier">
											<i class="mdi mdi-pencil"></i>
										</a>
										<button class="action-btn del" onclick="openModal('modal-{{ item.id }}')" title="Supprimer">
											<i class="mdi mdi-trash-can"></i>
										</button>
									</div>
								</td>
							{% endif %}
						</tr>
					{% else %}
						<tr class="empty-row">
							<td colspan="{{ is_granted('ROLE_ADMIN') ? 5 : 4 }}">
								<i class="mdi mdi-office-building-outline" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.35"></i>Aucune structure trouvée.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
			<div class="table-footer">
				<div class="pagination-info" id="pagination-info">—</div>
				<div class="pagination-controls" id="pagination-controls"></div>
			</div>
		</div>
	</div>

	{% if is_granted('ROLE_ADMIN') %}
		{% for item in structures %}
			<div class="modal-overlay" id="modal-{{ item.id }}">
				<div class="modal-box">
					<div class="modal-icon">
						<i class="mdi mdi-trash-can-outline"></i>
					</div>
					<div class="modal-title">Supprimer cette structure ?</div>
					<div class="modal-text">Vous êtes sur le point de supprimer
						<strong>{{ item.nom }}</strong>.<br/>Cette action est irréversible.</div>
					<div class="modal-actions">
						<button class="btn-ghost" onclick="closeModal('modal-{{ item.id }}')">Annuler</button>
						<form method="post" action="{{ path('app_admin_structure_delete', {id: item.id}) }}" style="display:inline;">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
								<button type="submit" class="btn-danger">
									<i class="mdi mdi-trash-can"></i>
									Supprimer</button>
							</form>
					</div>
				</div>
			</div>
		{% endfor %}
	{% endif %}
{% endblock %}
