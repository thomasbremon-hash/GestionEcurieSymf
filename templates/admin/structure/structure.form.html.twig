{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ structureId is not null ? 'Modifier une structure' : 'Ajouter une structure' }}
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_structures') }}">Structures</a>
      <span class="sep">›</span>
      <span class="current">{{ structureId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Structures</div>
        <h1 class="page-title">{{ structureId is not null ? 'Modifier la structure' : 'Ajouter une structure' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon" style="background:var(--accent-light);color:var(--accent);">
          <i class="mdi mdi-office-building-outline"></i>
        </div>
        <h2 class="form-card-title">{{ structureId is not null ? 'Modifier les informations' : 'Nouvelle structure' }}</h2>
      </div>

      {{ form_start(formStructure, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Identité ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-domain"></i> Identité
          </div>
          <div class="fields-row cols-1">
            <div class="form-field">
              {{ form_label(formStructure.nom) }}
              {{ form_widget(formStructure.nom) }}
              <div class="field-error">{{ form_errors(formStructure.nom) }}</div>
            </div>
          </div>
        </div>

        {# ── Adresse ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-map-marker-outline"></i> Adresse
          </div>
          <div class="fields-row cols-1" style="margin-bottom:1.25rem;">
            <div class="form-field">
              {{ form_label(formStructure.rue) }}
              {{ form_widget(formStructure.rue) }}
              <div class="field-error">{{ form_errors(formStructure.rue) }}</div>
            </div>
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formStructure.ville) }}
              {{ form_widget(formStructure.ville) }}
              <div class="field-error">{{ form_errors(formStructure.ville) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formStructure.cp) }}
              {{ form_widget(formStructure.cp) }}
              <div class="field-error">{{ form_errors(formStructure.cp) }}</div>
            </div>
          </div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_structures') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ structureId is not null ? 'content-save' : 'plus-circle' }}"></i>
          {{ structureId is not null ? 'Enregistrer les modifications' : 'Ajouter la structure' }}
        </button>
      </div>

      {{ form_end(formStructure) }}
    </div>
  </div>
{% endblock %}
