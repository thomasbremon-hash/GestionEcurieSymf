{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ chevalId is not null ? 'Modifier un cheval' : 'Ajouter un cheval' }}
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_chevaux') }}">Chevaux</a>
      <span class="sep">›</span>
      <span class="current">{{ chevalId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Chevaux</div>
        <h1 class="page-title">{{ chevalId is not null ? 'Modifier le cheval' : 'Ajouter un cheval' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon" style="background:var(--green-light);color:var(--green);">
          <i class="mdi mdi-chess-knight"></i>
        </div>
        <h2 class="form-card-title">{{ chevalId is not null ? 'Modifier les informations' : 'Nouveau cheval' }}</h2>
      </div>

      {{ form_start(formCheval, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Identité ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-horseshoe"></i> Identité
          </div>
          <div class="fields-row cols-2" style="margin-bottom:1.25rem;">
            <div class="form-field">
              {{ form_label(formCheval.nom) }}
              {{ form_widget(formCheval.nom) }}
              <div class="field-error">{{ form_errors(formCheval.nom) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formCheval.race) }}
              {{ form_widget(formCheval.race) }}
              <div class="field-error">{{ form_errors(formCheval.race) }}</div>
            </div>
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formCheval.sexe) }}
              {{ form_widget(formCheval.sexe) }}
              <div class="field-error">{{ form_errors(formCheval.sexe) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formCheval.dateNaissance) }}
              {{ form_widget(formCheval.dateNaissance) }}
              <div class="field-error">{{ form_errors(formCheval.dateNaissance) }}</div>
            </div>
          </div>
        </div>

        {# ── Propriétaires ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-account-multiple-outline"></i> Propriétaires
          </div>

          <div id="chevalProprietaires-error" class="proprietaire-error-msg" style="display:none;">
            <i class="mdi mdi-alert-circle"></i> Le total des pourcentages ne peut pas dépasser 100 %
          </div>

          <div id="chevalProprietaires-wrapper">
            {% for cp in formCheval.chevalProprietaires %}
              <div class="proprietaire-row collection-item">
                <div class="form-field" style="flex:1 1 220px;">
                  {{ form_label(cp.proprietaire, 'Propriétaire') }}
                  {{ form_widget(cp.proprietaire) }}
                  <div class="field-error">{{ form_errors(cp.proprietaire) }}</div>
                </div>

                <div class="form-field" style="flex:0 0 130px;">
                  {{ form_label(cp.pourcentage, 'Pourcentage (%)') }}
                  {{ form_widget(cp.pourcentage) }}
                  <div class="field-error pourcentage-error" style="display:none;">Dépasse 100 %</div>
                  <div class="field-error">{{ form_errors(cp.pourcentage) }}</div>
                </div>

                <div class="proprietaire-row-actions">
                  <button type="button" class="action-btn edit jb-add-collection" title="Ajouter une ligne"><i class="mdi mdi-plus"></i></button>
                  <button type="button" class="action-btn del jb-remove-collection" title="Supprimer cette ligne"><i class="mdi mdi-delete-sweep"></i></button>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="field-error" style="margin-top:.5rem;">{{ form_errors(formCheval.chevalProprietaires) }}</div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_chevaux') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom" id="submit-btn">
          <i class="mdi mdi-{{ chevalId is not null ? 'content-save' : 'horse' }}"></i>
          {{ chevalId is not null ? 'Enregistrer les modifications' : 'Créer le cheval' }}
        </button>
      </div>

      {{ form_end(formCheval) }}
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const wrapper = document.getElementById('chevalProprietaires-wrapper')
      const submitBtn = document.getElementById('submit-btn')
      const errorMsg = document.getElementById('chevalProprietaires-error')
    
      function updateIndexes() {
        wrapper.querySelectorAll('.collection-item').forEach((el, idx) => {
          el.querySelectorAll('select, input').forEach((input) => {
            const name = input.getAttribute('name')
            if (name) input.setAttribute('name', name.replace(/\[\d+\]/, '[' + idx + ']'))
          })
        })
      }
    
      function updateTotal() {
        let total = 0
        wrapper.querySelectorAll('.collection-item').forEach((item) => {
          const input = item.querySelector('input[type="number"]')
          if (input) total += parseFloat(input.value) || 0
        })
        if (total > 100) {
          submitBtn.disabled = true
          errorMsg.style.display = 'flex'
          wrapper.querySelectorAll('.pourcentage-error').forEach((p) => (p.style.display = 'block'))
        } else {
          submitBtn.disabled = false
          errorMsg.style.display = 'none'
          wrapper.querySelectorAll('.pourcentage-error').forEach((p) => (p.style.display = 'none'))
        }
      }
    
      function updateRemoveButtons() {
        const allItems = wrapper.querySelectorAll('.collection-item')
        const removeBtns = wrapper.querySelectorAll('.jb-remove-collection')
        removeBtns.forEach((btn) => (btn.disabled = allItems.length <= 1))
      }
    
      wrapper.addEventListener('click', (e) => {
        const target = e.target.closest('button')
        if (!target) return
    
        if (target.classList.contains('jb-remove-collection')) {
          target.closest('.collection-item').remove()
          updateIndexes()
          updateTotal()
          updateRemoveButtons()
        }
    
        if (target.classList.contains('jb-add-collection')) {
          const prototype = wrapper.querySelector('.collection-item')
          if (!prototype) return
          const clone = prototype.cloneNode(true)
          clone.querySelectorAll('input, select').forEach((input) => {
            if (input.tagName === 'INPUT') input.value = ''
            if (input.tagName === 'SELECT') input.selectedIndex = 0
          })
          wrapper.appendChild(clone)
          updateIndexes()
          updateTotal()
          updateRemoveButtons()
        }
      })
    
      wrapper.addEventListener('input', (e) => {
        if (e.target.tagName === 'INPUT' && e.target.type === 'number') updateTotal()
      })
    
      updateTotal()
      updateRemoveButtons()
    })
  </script>
{% endblock %}
