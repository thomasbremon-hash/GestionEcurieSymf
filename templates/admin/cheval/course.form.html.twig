{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ courseId is not null ? 'Modifier une course' : 'Ajouter une course' }}
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_courses') }}">Courses</a>
      <span class="sep">›</span>
      <span class="current">{{ courseId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Courses</div>
        <h1 class="page-title">{{ courseId is not null ? 'Modifier la course' : 'Ajouter une course' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon" style="background:var(--blue-light);color:var(--blue);">
          <i class="mdi mdi-flag-checkered"></i>
        </div>
        <h2 class="form-card-title">{{ courseId is not null ? 'Modifier les informations' : 'Nouvelle course' }}</h2>
      </div>

      {{ form_start(formCourse, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Identification ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-flag-checkered"></i> Identification
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formCourse.nom) }}
              {{ form_widget(formCourse.nom) }}
              <div class="field-error">{{ form_errors(formCourse.nom) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formCourse.lieu) }}
              {{ form_widget(formCourse.lieu) }}
              <div class="field-error">{{ form_errors(formCourse.lieu) }}</div>
            </div>
          </div>
        </div>

        {# ── Détails ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-calendar-clock"></i> Détails
          </div>
          <div class="fields-row cols-2" style="margin-bottom:1.25rem;">
            <div class="form-field">
              {{ form_label(formCourse.dateCourse) }}
              {{ form_widget(formCourse.dateCourse) }}
              <div class="field-error">{{ form_errors(formCourse.dateCourse) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formCourse.distance) }}
              {{ form_widget(formCourse.distance) }}
              <div class="field-error">{{ form_errors(formCourse.distance) }}</div>
            </div>
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formCourse.type) }}
              {{ form_widget(formCourse.type) }}
              <div class="field-error">{{ form_errors(formCourse.type) }}</div>
            </div>
          </div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_courses') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ courseId is not null ? 'content-save' : 'plus-circle' }}"></i>
          {{ courseId is not null ? 'Enregistrer les modifications' : 'Ajouter la course' }}
        </button>
      </div>

      {{ form_end(formCourse) }}
    </div>
  </div>
{% endblock %}
