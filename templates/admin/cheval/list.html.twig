{% extends 'layouts/base.admin.html.twig' %}
{% block title %}BackOffice | Liste des chevaux
{% endblock %}
{% block body %}
	<div class="admin-wrapper--wide">
		{% for label, messages in app.flashes(['success', 'danger']) %}
			{% for message in messages %}
				<div class="flash {{ label }}">
					<span>
						<i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i>
						{{ message }}</span>
					<button class="flash-close" onclick="this.parentElement.remove()">
						<i class="mdi mdi-close"></i>
					</button>
				</div>
			{% endfor %}
		{% endfor %}

		<div class="page-top">
			<div>
				<div class="page-eyebrow"><a href="{{ path('app_admin') }}">Dashboard</a> › <span>Chevaux</span></div>
				<h1 class="page-title">Chevaux
					<span class="subtitle">{{ chevaux|length }}
						au total</span>
				</h1>
			</div>
			<div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
				<a href="{{ path('app_admin_cheval_export_csv') }}" class="btn-ghost" style="display:inline-flex;align-items:center;gap:0.4rem;">
					<i class="mdi mdi-file-delimited-outline"></i> Export CSV
				</a>
				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('app_admin_cheval_new') }}" class="btn-primary-custom">
						<i class="mdi mdi-plus"></i>
						Ajouter un cheval</a>
				{% endif %}
			</div>
		</div>

		<div class="table-card">
			<div class="table-card-header">
				<div class="table-card-header-left">
					<div class="table-card-title">
						<i class="mdi mdi-horse" style="color:var(--accent)"></i>
						Liste des chevaux
						<span class="count-badge">{{ chevaux|length }}</span>
					</div>
					<div class="per-page-wrap">
						Afficher<select id="per-page-select">
							<option value="10">10</option>
							<option value="25" selected>25</option>
							<option value="50">50</option>
							<option value="100">100</option>
						</select>par page
					</div>
				</div>
				<div class="search-wrap">
					<i class="mdi mdi-magnify search-icon"></i>
					<input type="text" id="search-input" placeholder="Rechercher…"/>
				</div>
			</div>

			<table class="data-table"
				data-sortable="true"
				data-bulk-delete="true"
				data-bulk-delete-url="{{ path('app_admin_cheval_delete_bulk') }}"
				data-bulk-csrf-token="{{ csrf_token('bulk-delete') }}">
				<thead>
					<tr>
						<th data-sort="string">Cheval</th>
						<th data-sort="string">Race</th>
						<th data-sort="string">Sexe</th>
						<th data-sort="date">Date de naissance</th>
						<th>Propriétaires</th>
						{% if is_granted('ROLE_ADMIN') %}
							<th style="text-align:right">Actions</th>
						{% endif %}
					</tr>
				</thead>
				<tbody id="cheval-tbody" data-noun="cheval" data-noun-plural="chevaux">
					{% for cheval in chevaux %}
						<tr data-index="{{ loop.index0 }}" data-id="{{ cheval.id }}">
							<td>
								<a href="{{ path('app_admin_cheval_show', {id: cheval.id}) }}" class="user-cell" style="text-decoration:none;color:inherit;">
									<div class="user-avatar" style="background:var(--green);">{{ cheval.nom|slice(0,1)|upper }}</div>
									<div class="user-name">{{ cheval.nom }}</div>
								</a>
							</td>
							<td>
								<span style="font-size:0.88rem;color:var(--ink-soft);">{{ cheval.race ?: '—' }}</span>
							</td>
							<td>
								{% if cheval.sexe %}
									<span class="pill tag-neutral" style="text-transform:capitalize;">{{ cheval.sexe }}</span>
									{% else %}—
								{% endif %}
							</td>
							<td>
								<span style="font-size:0.88rem;color:var(--ink-soft);">{{ cheval.dateNaissance ? cheval.dateNaissance|date('d/m/Y') : '—' }}</span>
							</td>
							<td>
								{% if cheval.chevalProprietaires|length > 0 %}
									<div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
										{% for cp in cheval.chevalProprietaires %}
											<span class="pill pill-user">{{ cp.proprietaire.prenom }}
												{{ cp.proprietaire.nom }}
												<span style="opacity:0.65;">({{ cp.pourcentage }}%)</span>
											</span>
										{% endfor %}
									</div>
								{% else %}
									<span style="color:var(--ink-muted);font-size:0.85rem;font-style:italic;">Aucun</span>
								{% endif %}
							</td>
							{% if is_granted('ROLE_ADMIN') %}
								<td>
									<div class="action-btns">
										<a href="{{ path('app_admin_cheval_show', {id: cheval.id}) }}" class="action-btn" title="Voir">
											<i class="mdi mdi-eye"></i>
										</a>
										<a href="{{ path('app_admin_cheval_update', {id: cheval.id}) }}" class="action-btn edit" title="Modifier">
											<i class="mdi mdi-pencil"></i>
										</a>
										<button class="action-btn del" onclick="openModal('modal-{{ cheval.id }}')" title="Supprimer">
											<i class="mdi mdi-trash-can"></i>
										</button>
									</div>
								</td>
							{% endif %}
						</tr>
					{% else %}
						<tr class="empty-row">
							<td colspan="{{ is_granted('ROLE_ADMIN') ? 7 : 6 }}">
								<i class="mdi mdi-horse" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.35"></i>Aucun cheval trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
			<div class="table-footer">
				<div class="pagination-info" id="pagination-info">—</div>
				<div class="pagination-controls" id="pagination-controls"></div>
			</div>
		</div>
	</div>

	{% if is_granted('ROLE_ADMIN') %}
		{% for cheval in chevaux %}
			<div class="modal-overlay" id="modal-{{ cheval.id }}">
				<div class="modal-box">
					<div class="modal-icon">
						<i class="mdi mdi-trash-can-outline"></i>
					</div>
					<div class="modal-title">Supprimer ce cheval ?</div>
					<div class="modal-text">
						Vous êtes sur le point de supprimer <strong>{{ cheval.nom }}</strong>.
						{% set nbDep = cheval.deplacement|length %}
						{% set nbPart = cheval.participations|length %}
						{% if nbDep > 0 or nbPart > 0 %}
							<br/><br/>
							<div class="modal-warning">
								<i class="mdi mdi-alert"></i>
								Ce cheval a :
								{% if nbDep > 0 %}<br/>• <strong>{{ nbDep }}</strong> déplacement{{ nbDep > 1 ? 's' }}{% endif %}
								{% if nbPart > 0 %}<br/>• <strong>{{ nbPart }}</strong> participation{{ nbPart > 1 ? 's' }} à des courses{% endif %}
								<br/>associés qui seront également supprimés.
							</div>
						{% endif %}
						<br/>Cette action est irréversible.
					</div>
					<div class="modal-actions">
						<button class="btn-ghost" onclick="closeModal('modal-{{ cheval.id }}')">Annuler</button>
						<form method="post" action="{{ path('app_admin_cheval_delete', {id: cheval.id}) }}" style="display:inline;">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cheval.id) }}">
								<button type="submit" class="btn-danger">
									<i class="mdi mdi-trash-can"></i>
									Supprimer</button>
							</form>
					</div>
				</div>
			</div>
		{% endfor %}
	{% endif %}
{% endblock %}
