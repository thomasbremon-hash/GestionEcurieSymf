{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | Détails du mois
{% endblock %}

{% block body %}
  <div class="admin-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_mois_gestion') }}">Gestion mensuelle</a>
      <span class="sep">›</span>
      <span class="current">Détails du mois</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top">
      <div>
        <div class="page-eyebrow">Admin › Gestion financière</div>
        <h1 class="page-title">
          Relevé
          <span class="subtitle">{{ '%02d'|format(moisDeGestion.mois) }} / {{ moisDeGestion.annee }}</span>
        </h1>
      </div>
      <a href="{{ path('app_admin_mois_gestion') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Retour</a>
    </div>

    {# ── Calcul total global ── #}
    {% set total_mois = 0 %}
    {% for cheval in chevaux %}
      {% for cp in moisDeGestion.chevalProduits %}
        {% if cp.cheval.id == cheval.id and cp.quantite > 0 %}
          {% set total_mois = total_mois + cp.quantite * cp.prixUnitaire %}
        {% endif %}
      {% endfor %}
    {% endfor %}

    {# ── KPI ── #}
    <div class="kpi-row" style="margin-bottom:2rem;">
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-accent">
          <i class="mdi mdi-horseshoe"></i>
        </div>
        <div>
          <div class="kpi-label">Chevaux</div>
          <div class="kpi-value">{{ chevaux|length }}</div>
        </div>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon kpi-icon-green">
          <i class="mdi mdi-cash-multiple"></i>
        </div>
        <div>
          <div class="kpi-label">Total du mois</div>
          <div class="kpi-value" style="font-size:1.4rem;">{{ total_mois|number_format(2, ',', ' ') }} €</div>
        </div>
      </div>
    </div>

    {# ── Grille des chevaux ── #}
    <div class="chevaux-grid">
      {% for cheval in chevaux %}
        {% set total_cheval = 0 %}
        {% set deplacements_affiches = [] %}
        {% set lignes = [] %}

        {% for cp in moisDeGestion.chevalProduits %}
          {% if cp.cheval.id == cheval.id and cp.quantite > 0 %}
            {% set afficher = true %}
            {% if cp.produit.nom == 'Déplacement' %}
              {% set key = cp.commentaire %}
              {% if key in deplacements_affiches %}
                {% set afficher = false %}
              {% else %}
                {% set deplacements_affiches = deplacements_affiches|merge([key]) %}
              {% endif %}
            {% endif %}
            {% if afficher %}
              {% set total_produit = cp.quantite * cp.prixUnitaire %}
              {% set total_cheval = total_cheval + total_produit %}
            {% endif %}
          {% endif %}
        {% endfor %}

        <div class="cheval-card {% if total_cheval == 0 %}{% endif %}">
          {# Header cheval #}
          <div class="cheval-card-header">
            <div class="cheval-card-avatar">{{ cheval.nom|slice(0, 1)|upper }}</div>
            <div>
              <div class="cheval-card-name">{{ cheval.nom }}</div>
              <div class="cheval-card-sub">
                {% set nb_produits = 0 %}
                {% for cp in moisDeGestion.chevalProduits %}
                  {% if cp.cheval.id == cheval.id and cp.quantite > 0 %}
                    {% set nb_produits = nb_produits + 1 %}
                  {% endif %}
                {% endfor %}
                {{ nb_produits }} prestation{{ nb_produits > 1 ? 's' }}
              </div>
            </div>
            <div class="cheval-card-total">{{ total_cheval|number_format(2, ',', ' ') }} €</div>
          </div>

          {# Table produits #}
          {% if total_cheval > 0 %}
            <table class="cheval-table">
              <thead>
                <tr>
                  <th>Prestation</th>
                  <th class="text-right">Qté</th>
                  <th class="text-right">P.U.</th>
                  <th class="text-right">Total</th>
                </tr>
              </thead>
              <tbody>
                {% set deplacements_affiches = [] %}
                {% for cp in moisDeGestion.chevalProduits %}
                  {% if cp.cheval.id == cheval.id and cp.quantite > 0 %}
                    {% set afficher = true %}
                    {% if cp.produit.nom == 'Déplacement' %}
                      {% set key = cp.commentaire %}
                      {% if key in deplacements_affiches %}
                        {% set afficher = false %}
                      {% else %}
                        {% set deplacements_affiches = deplacements_affiches|merge([key]) %}
                      {% endif %}
                    {% endif %}
                    {% if afficher %}
                      {% set total_produit = cp.quantite * cp.prixUnitaire %}
                      <tr>
                        <td>
                          {% if cp.produit.nom == 'Déplacement' %}
                            <span class="produit-label produit-deplacement">
                              <i class="mdi mdi-car"></i>
                              {{ cp.commentaire ? : cp.produit.nom }}
                            </span>
                          {% else %}
                            <span class="produit-label">{{ cp.produit.nom }}</span>
                          {% endif %}
                        </td>
                        <td class="text-right qty-cell">{{ cp.quantite }}</td>
                        <td class="text-right muted-cell">{{ cp.prixUnitaire|number_format(2, ',', ' ') }} €</td>
                        <td class="text-right total-cell">{{ total_produit|number_format(2, ',', ' ') }} €</td>
                      </tr>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="3" class="tfoot-label">Sous-total</td>
                  <td class="text-right tfoot-value">{{ total_cheval|number_format(2, ',', ' ') }} €</td>
                </tr>
              </tfoot>
            </table>
          {% else %}
            <div class="empty-state" style="padding:1.5rem;">
              <i class="mdi mdi-minus-circle-outline" style="font-size:1.2rem;display:block;margin-bottom:.4rem;opacity:.3"></i>
              Aucune prestation ce mois
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {# ── Total global ── #}
    <div class="total-banner">
      <div class="total-banner-label">
        <i class="mdi mdi-calculator-variant"></i>
        Total général du mois {{ '%02d'|format(moisDeGestion.mois) }}/{{ moisDeGestion.annee }}
      </div>
      <div class="total-banner-value">{{ total_mois|number_format(2, ',', ' ') }} €</div>
    </div>
  </div>

  <style>
   
  </style>
{% endblock %}
