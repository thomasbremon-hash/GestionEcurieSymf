{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | Liste des déplacements
{% endblock %}

{% block body %}
  <div class="admin-wrapper--wide">
    {# ── Flash ── #}
    {% for label, messages in app.flashes(['success', 'danger']) %}
      {% for message in messages %}
        <div class="flash {{ label }}">
          <span><i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i> {{ message }}</span>
          <button class="flash-close" onclick="this.parentElement.remove()"><i class="mdi mdi-close"></i></button>
        </div>
      {% endfor %}
    {% endfor %}

    {# ── Page top ── #}
    <div class="page-top">
      <div>
        <div class="page-eyebrow">Admin › Gestion</div>
        <h1 class="page-title">Déplacements <span class="subtitle">{{ deplacements|length }} au total</span></h1>
      </div>
      <a href="{{ path('app_admin_deplacement_new') }}" class="btn-primary-custom"><i class="mdi mdi-plus"></i> Ajouter un déplacement</a>
    </div>

    {# ── Table card ── #}
    <div class="table-card">
      <div class="table-card-header">
        <div class="table-card-header-left">
          <div class="table-card-title">
            <i class="mdi mdi-map-marker-distance" style="color:var(--blue)"></i>
            Liste des déplacements
            <span class="count-badge">{{ deplacements|length }}</span>
          </div>
          <div class="per-page-wrap">
            Afficher<select id="per-page-select">
              <option value="10">10</option>
              <option value="25" selected>25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>par page
          </div>
        </div>
        <div class="search-wrap">
          <i class="mdi mdi-magnify search-icon"></i>
          <input type="text" id="search-input" placeholder="Rechercher…" />
        </div>
      </div>

      <table class="data-table">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Date</th>
            <th>Chevaux</th>
            <th>Structure</th>
            <th>Entreprise</th>
            <th>Distance</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="deplacement-tbody">
          {% set moisActuel = null %}

          {% for deplacement in deplacements %}
            {% set moisDeplacement = deplacement.date|date('Y-m') %}

            {# ── Séparateur de mois ── #}
            {% if moisActuel != moisDeplacement %}
              <tr class="month-separator-row" data-separator="true">
                <td colspan="7">
                  <span class="month-separator-label">
                    <i class="mdi mdi-calendar-month-outline"></i>
                    {{ deplacement.date|format_datetime(locale='fr', pattern='MMMM yyyy')|capitalize }}
                  </span>
                </td>
              </tr>
              {% set moisActuel = moisDeplacement %}
            {% endif %}

            <tr data-index="{{ loop.index0 }}" data-month="{{ moisDeplacement }}">
              {# Nom #}
              <td>
                <div class="user-cell">
                  <div class="user-avatar" style="background:var(--blue);">{{ deplacement.nom|slice(0, 1)|upper }}</div>
                  <div class="user-name">{{ deplacement.nom }}</div>
                </div>
              </td>

              {# Date #}
              <td>
                <span style="font-size:0.88rem;color:var(--ink-soft);">{{ deplacement.date|date('d/m/Y') }}</span>
              </td>

              {# Chevaux #}
              <td>
                {% if (deplacement.chevaux|length) > 0 %}
                  <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
                    {% for cheval in deplacement.chevaux %}
                      <span class="pill tag-green">{{ cheval.nom }}</span>
                    {% endfor %}
                  </div>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;font-style:italic;">Aucun</span>
                {% endif %}
              </td>

              {# Structure #}
              <td>
                {% if deplacement.structure is not null %}
                  <span class="pill" style="background:var(--gold-light);color:var(--gold);border:1px solid rgba(160,124,48,.2);">
                    <i class="mdi mdi-office-building-outline"></i>
                    {{ deplacement.structure.nom }}
                  </span>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
                {% endif %}
              </td>

              {# Entreprise #}
              <td>
                {% if deplacement.entreprise is not null %}
                  <span class="pill pill-user">
                    <i class="mdi mdi-domain"></i>
                    {{ deplacement.entreprise.nom }}
                  </span>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
                {% endif %}
              </td>

              {# Distance #}
              <td>
                {% if deplacement.distance %}
                  <span class="pill tag-accent" style="font-family:'Sora',sans-serif;font-weight:700;">
                    <i class="mdi mdi-map-marker-distance"></i>
                    {{ deplacement.distance|number_format(2, ',', ' ') }} km
                  </span>
                {% else %}
                  <span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
                {% endif %}
              </td>

              {# Actions #}
              <td>
                <div class="action-btns">
                  <a href="{{ path('app_admin_deplacement_update', { id: deplacement.id }) }}" class="action-btn edit" title="Modifier"><i class="mdi mdi-pencil"></i></a>
                  <button class="action-btn del" onclick="openModal('modal-{{ deplacement.id }}')" title="Supprimer"><i class="mdi mdi-trash-can"></i></button>
                </div>
              </td>
            </tr>
          {% else %}
            <tr class="empty-row">
              <td colspan="7">
                <i class="mdi mdi-map-marker-off-outline" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.35"></i>
                Aucun déplacement trouvé.
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="table-footer">
        <div class="pagination-info" id="pagination-info">—</div>
        <div class="pagination-controls" id="pagination-controls"></div>
      </div>
    </div>
  </div>

  {# ── Modals suppression ── #}
  {% for deplacement in deplacements %}
    <div class="modal-overlay" id="modal-{{ deplacement.id }}">
      <div class="modal-box">
        <div class="modal-icon">
          <i class="mdi mdi-trash-can-outline"></i>
        </div>
        <div class="modal-title">Supprimer ce déplacement ?</div>
        <div class="modal-text">
          Vous êtes sur le point de supprimer <strong>{{ deplacement.nom }}</strong>
          du <strong>{{ deplacement.date|date('d/m/Y') }}</strong>.<br />
          Cette action est irréversible.
        </div>
        <div class="modal-actions">
          <button class="btn-ghost" onclick="closeModal('modal-{{ deplacement.id }}')">Annuler</button>
          <a href="{{ path('app_admin_deplacement_delete', { id: deplacement.id }) }}" class="btn-danger"><i class="mdi mdi-trash-can"></i> Supprimer</a>
        </div>
      </div>
    </div>
  {% endfor %}
{% endblock %}
