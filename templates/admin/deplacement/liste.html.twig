{% extends 'layouts/base.admin.html.twig' %}
{% block title %}BackOffice | Liste des déplacements
{% endblock %}
{% block body %}
	<div class="admin-wrapper--wide">
		{% for label, messages in app.flashes(['success', 'danger']) %}
			{% for message in messages %}
				<div class="flash {{ label }}">
					<span>
						<i class="mdi mdi-{{ label == 'success' ? 'check-circle' : 'alert-circle' }}"></i>
						{{ message }}</span>
					<button class="flash-close" onclick="this.parentElement.remove()">
						<i class="mdi mdi-close"></i>
					</button>
				</div>
			{% endfor %}
		{% endfor %}

		<div class="page-top">
			<div>
				<div class="page-eyebrow"><a href="{{ path('app_admin') }}">Dashboard</a> › <span>Déplacements</span></div>
				<h1 class="page-title">Déplacements
					<span class="subtitle">{{ deplacements|length }}
						au total</span>
				</h1>
			</div>
			{% if is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_admin_deplacement_new') }}" class="btn-primary-custom">
					<i class="mdi mdi-plus"></i>
					Ajouter un déplacement</a>
			{% endif %}
		</div>

		<div class="table-card">
			<div class="table-card-header">
				<div class="table-card-header-left">
					<div class="table-card-title">
						<i class="mdi mdi-map-marker-distance" style="color:var(--blue)"></i>
						Liste des déplacements
						<span class="count-badge">{{ deplacements|length }}</span>
					</div>
					<div class="per-page-wrap">
						Afficher<select id="per-page-select">
							<option value="10">10</option>
							<option value="25" selected>25</option>
							<option value="50">50</option>
							<option value="100">100</option>
						</select>par page
					</div>
				</div>
				<div class="search-wrap">
					<i class="mdi mdi-magnify search-icon"></i>
					<input type="text" id="search-input" placeholder="Rechercher…"/>
				</div>
			</div>

			<table class="data-table"
					data-sortable="true"
					data-bulk-delete="true"
					data-bulk-delete-url="{{ path('app_admin_deplacement_delete_bulk') }}"
					data-bulk-csrf-token="{{ csrf_token('bulk-delete') }}">
				<thead>
					<tr>
						<th data-sort="string">Nom</th>
						<th data-sort="date">Date</th>
						<th>Chevaux</th>
						<th>Structure</th>
						<th>Entreprise</th>
						<th>Distance</th>
						{% if is_granted('ROLE_ADMIN') %}
							<th style="text-align:right">Actions</th>
						{% endif %}
					</tr>
				</thead>
				<tbody id="deplacement-tbody" data-noun="déplacement" data-noun-plural="déplacements">
					{% set currentEntreprise = null %}
					{% set moisActuel = null %}
					{% for deplacement in deplacements %}
						{% set entrepriseNom = deplacement.entreprise ? deplacement.entreprise.nom : 'Sans entreprise' %}
						{% if currentEntreprise != entrepriseNom %}
							<tr class="month-separator-row" data-separator="true">
								<td colspan="{{ is_granted('ROLE_ADMIN') ? 7 : 6 }}">
									<span class="month-separator-label" style="font-size:0.88rem;">
										<i class="mdi mdi-domain"></i>
										{{ entrepriseNom }}
									</span>
								</td>
							</tr>
							{% set currentEntreprise = entrepriseNom %}
							{% set moisActuel = null %}
						{% endif %}
						{% set moisDeplacement = deplacement.date|date('Y-m') %}
						{% if moisActuel != moisDeplacement %}
							<tr class="month-separator-row" data-separator="true">
								<td colspan="{{ is_granted('ROLE_ADMIN') ? 7 : 6 }}">
									<span class="month-separator-label" style="font-size:0.8rem;opacity:0.7;padding-left:1rem;">
										<i class="mdi mdi-calendar-month-outline"></i>
										{{ deplacement.date|format_datetime(locale='fr', pattern='MMMM yyyy')|capitalize }}
									</span>
								</td>
							</tr>
							{% set moisActuel = moisDeplacement %}
						{% endif %}
						<tr data-index="{{ loop.index0 }}" data-month="{{ moisDeplacement }}" data-id="{{ deplacement.id }}">
							<td>
								<div class="user-cell">
									<div class="user-avatar" style="background:var(--blue);">{{ deplacement.nom|slice(0,1)|upper }}</div>
									<div class="user-name">{{ deplacement.nom }}</div>
								</div>
							</td>
							<td>
								<span style="font-size:0.88rem;color:var(--ink-soft);">{{ deplacement.date|date('d/m/Y') }}</span>
							</td>
							<td>
								{% if deplacement.chevaux|length > 0 %}
									<div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
										{% for cheval in deplacement.chevaux %}
											<span class="pill tag-green">{{ cheval.nom }}</span>
										{% endfor %}
									</div>
								{% else %}
									<span style="color:var(--ink-muted);font-size:0.85rem;font-style:italic;">Aucun</span>
								{% endif %}
							</td>
							<td>
								{% if deplacement.structure is not null %}
									<span class="pill" style="background:var(--gold-light);color:var(--gold);border:1px solid rgba(160,124,48,.2);">
										<i class="mdi mdi-office-building-outline"></i>
										{{ deplacement.structure.nom }}
									</span>
								{% else %}
									<span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
								{% endif %}
							</td>
							<td>
								{% if deplacement.entreprise is not null %}
									<span class="pill pill-user">
										<i class="mdi mdi-domain"></i>
										{{ deplacement.entreprise.nom }}</span>
								{% else %}
									<span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
								{% endif %}
							</td>
							<td>
								{% if deplacement.distance %}
									<span class="pill tag-accent" style="font-family:'Sora',sans-serif;font-weight:700;">
										<i class="mdi mdi-map-marker-distance"></i>
										{{ deplacement.distance|number_format(2, ',', ' ') }}
										km
									</span>
								{% else %}
									<span style="color:var(--ink-muted);font-size:0.85rem;">N/A</span>
								{% endif %}
							</td>
							{% if is_granted('ROLE_ADMIN') %}
								<td>
									<div class="action-btns">
										<a href="{{ path('app_admin_deplacement_update', {id: deplacement.id}) }}" class="action-btn edit" title="Modifier">
											<i class="mdi mdi-pencil"></i>
										</a>
										<button class="action-btn del" onclick="openModal('modal-{{ deplacement.id }}')" title="Supprimer">
											<i class="mdi mdi-trash-can"></i>
										</button>
									</div>
								</td>
							{% endif %}
						</tr>
					{% else %}
						<tr class="empty-row">
							<td colspan="{{ is_granted('ROLE_ADMIN') ? 8 : 7 }}">
								<i class="mdi mdi-map-marker-off-outline" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.35"></i>Aucun déplacement trouvé.
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
			<div class="table-footer">
				<div class="pagination-info" id="pagination-info">—</div>
				<div class="pagination-controls" id="pagination-controls"></div>
			</div>
		</div>
	</div>

	{% if is_granted('ROLE_ADMIN') %}
		{% for deplacement in deplacements %}
			<div class="modal-overlay" id="modal-{{ deplacement.id }}">
				<div class="modal-box">
					<div class="modal-icon">
						<i class="mdi mdi-trash-can-outline"></i>
					</div>
					<div class="modal-title">Supprimer ce déplacement ?</div>
					<div class="modal-text">Vous êtes sur le point de supprimer
						<strong>{{ deplacement.nom }}</strong>
						du
						<strong>{{ deplacement.date|date('d/m/Y') }}</strong>.<br/>Cette action est irréversible.</div>
					<div class="modal-actions">
						<button class="btn-ghost" onclick="closeModal('modal-{{ deplacement.id }}')">Annuler</button>
						<form method="post" action="{{ path('app_admin_deplacement_delete', {id: deplacement.id}) }}" style="display:inline;">
								<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deplacement.id) }}">
								<button type="submit" class="btn-danger">
									<i class="mdi mdi-trash-can"></i>
									Supprimer</button>
							</form>
					</div>
				</div>
			</div>
		{% endfor %}
	{% endif %}
{% endblock %}
