{% extends 'layouts/base.admin.html.twig' %}

{% block title %}
  BackOffice | {{ deplacementId is not null ? 'Modifier un déplacement' : 'Ajouter un déplacement' }}
{% endblock %}

{% block body %}
  <div class="form-wrapper">
    {# ── Breadcrumb ── #}
    <div class="breadcrumb-row">
      <a href="{{ path('app_admin_deplacements') }}">Déplacements</a>
      <span class="sep">›</span>
      <span class="current">{{ deplacementId is not null ? 'Modifier' : 'Ajouter' }}</span>
    </div>

    {# ── Page top ── #}
    <div class="page-top" style="margin-bottom:1.5rem;">
      <div>
        <div class="page-eyebrow">Admin › Déplacements</div>
        <h1 class="page-title">{{ deplacementId is not null ? 'Modifier le déplacement' : 'Ajouter un déplacement' }}</h1>
      </div>
    </div>

    {# ── Form card ── #}
    <div class="form-card">
      <div class="form-card-header">
        <div class="section-icon" style="background:var(--blue-light);color:var(--blue);">
          <i class="mdi mdi-truck"></i>
        </div>
        <h2 class="form-card-title">{{ deplacementId is not null ? 'Modifier les informations' : 'Nouveau déplacement' }}</h2>
      </div>

      {{ form_start(formDeplacement, { attr: { novalidate: 'novalidate' } }) }}

      <div class="form-body">
        {# ── Informations générales ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-information-outline"></i> Informations générales
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formDeplacement.nom) }}
              {{ form_widget(formDeplacement.nom) }}
              <div class="field-error">{{ form_errors(formDeplacement.nom) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formDeplacement.date) }}
              {{ form_widget(formDeplacement.date) }}
              <div class="field-error">{{ form_errors(formDeplacement.date) }}</div>
            </div>
          </div>
        </div>

        {# ── Entreprise / Structure ── #}
        <div class="form-group">
          <div class="form-group-title">
            <i class="mdi mdi-domain"></i> Entreprise &amp; Structure
          </div>
          <div class="fields-row cols-2">
            <div class="form-field">
              {{ form_label(formDeplacement.entreprise) }}
              {{ form_widget(formDeplacement.entreprise) }}
              <div class="field-error">{{ form_errors(formDeplacement.entreprise) }}</div>
            </div>
            <div class="form-field">
              {{ form_label(formDeplacement.structure) }}
              {{ form_widget(formDeplacement.structure) }}
              <div class="field-error">{{ form_errors(formDeplacement.structure) }}</div>
            </div>
          </div>
        </div>

        {# ── Chevaux ── #}
        <div class="form-group" style="margin-bottom:0;">
          <div class="form-group-title">
            <i class="mdi mdi-horse"></i> Chevaux
          </div>
          <div class="checkbox-grid">
            {% for cheval in formDeplacement.chevaux %}
              <label class="checkbox-item">
                {{ form_widget(cheval) }}
                <span>{{ cheval.vars.label }}</span>
              </label>
            {% endfor %}
          </div>
          <div class="field-error" style="margin-top:.5rem;">{{ form_errors(formDeplacement.chevaux) }}</div>
        </div>
      </div>

      {# ── Footer ── #}
      <div class="form-footer">
        <a href="{{ path('app_admin_deplacements') }}" class="btn-ghost"><i class="mdi mdi-arrow-left"></i> Annuler</a>
        <button type="submit" class="btn-primary-custom">
          <i class="mdi mdi-{{ deplacementId is not null ? 'content-save' : 'plus-circle' }}"></i>
          {{ deplacementId is not null ? 'Enregistrer les modifications' : 'Ajouter le déplacement' }}
        </button>
      </div>

      {{ form_end(formDeplacement) }}
    </div>
  </div>
{% endblock %}
